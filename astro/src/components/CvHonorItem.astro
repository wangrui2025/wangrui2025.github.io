---
export interface Props {
  text: string;
  period: string;
  secondary?: boolean;
}

const { text, period, secondary = false } = Astro.props;
---

<div class="flex justify-between items-baseline gap-4 w-full">
  <span class={`text-base break-words ${secondary ? 'text-[#5e5d59] dark:text-[#87867f]' : 'text-text-primary dark:text-text-dark'}`}>
    {text}
  </span>
  <span class="text-xs text-[#5e5d59] dark:text-[#87867f] text-right shrink-0 whitespace-nowrap">
    {period}
  </span>
</div>
