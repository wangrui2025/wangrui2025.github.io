<link id="pokemon-favicon" rel="icon" type="image/png" href="https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/lotad.png" />
<script is:inline>
  (function() {
    var link = document.getElementById('pokemon-favicon');
    if (!link) return;

    // Fixed default favicon for first-time visitors
    var DEFAULT_FAVICON = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/lotad.png';
    var MANIFEST_URL = 'https://raw.githubusercontent.com/wangrui2025/sprites-gallery/main/public/icon-manifest.json';

    // Check if user has visited before
    var hasVisited = localStorage.getItem('favicon-initialized');

    if (!hasVisited) {
      // First visit: show Lotad as default
      link.href = DEFAULT_FAVICON;
      localStorage.setItem('favicon-initialized', 'true');
    } else {
      // Subsequent visits (refresh): random from regular/shiny
      fetch(MANIFEST_URL)
        .then(function(res) { return res.json(); })
        .then(function(manifest) {
          var allowedIds = ['pokemon-gen8-regular', 'pokemon-gen8-shiny'];
          var allowedSets = allowedIds.map(function(id) { return manifest.iconSets[id]; }).filter(Boolean);
          if (allowedSets.length === 0) throw new Error('No allowed icon sets');
          var set = allowedSets[Math.floor(Math.random() * allowedSets.length)];
          var icon = set.icons[Math.floor(Math.random() * set.icons.length)];
          link.href = icon.url;
        })
        .catch(function() {
          link.href = DEFAULT_FAVICON;
        });
    }
  })();
</script>
