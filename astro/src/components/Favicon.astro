---
interface Props {
  fixedFavicon?: boolean;
}
const { fixedFavicon = false } = Astro.props;
const smeargleUrl = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/smeargle.png';
const defaultUrl = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/lotad.png';
const initialHref = fixedFavicon ? smeargleUrl : defaultUrl;
---
<link id="pokemon-favicon" rel="icon" type="image/png" href={initialHref} />
{fixedFavicon && <>
  <link rel="icon" type="image/png" sizes="32x32" href={smeargleUrl} />
  <link rel="icon" type="image/png" sizes="192x192" href={smeargleUrl} />
  <link rel="apple-touch-icon" sizes="180x180" href={smeargleUrl} />
</>}
{!fixedFavicon && <>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</>}
<script is:inline>
  (function() {
    var link = document.getElementById('pokemon-favicon');
    if (!link) return;

    // Default: Lotad (set in HTML link href)
    var DEFAULT_FAVICON = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/lotad.png';
    var MANIFEST_URL = 'https://raw.githubusercontent.com/wangrui2025/sprites-gallery/main/public/icon-manifest.json?t=' + Date.now();

    // If page has data-fixed-favicon, skip randomization and use fixed Smeargle
    if (document.documentElement.hasAttribute('data-fixed-favicon')) {
      link.href = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/smeargle.png';
      return;
    }

    // Always random from regular + shiny on every page load
    fetch(MANIFEST_URL)
      .then(function(res) { return res.json(); })
      .then(function(manifest) {
        var allowedIds = ['pokemon-gen8-regular', 'pokemon-gen8-shiny'];
        var allowedSets = allowedIds.map(function(id) { return manifest.iconSets[id]; }).filter(Boolean);
        if (allowedSets.length === 0) throw new Error('No allowed icon sets');
        var set = allowedSets[Math.floor(Math.random() * allowedSets.length)];
        var icon = set.icons[Math.floor(Math.random() * set.icons.length)];
        link.href = icon.url + '?t=' + Date.now();
      })
      .catch(function() {
        // Keep default Lotad on error
      });
  })();
</script>
