<link id="pokemon-favicon" rel="icon" type="image/png" href="" />
<script is:inline>
  (function() {
    var link = document.getElementById('pokemon-favicon');
    if (!link) return;
    var MANIFEST_URL = 'https://raw.githubusercontent.com/wangrui2025/sprites-gallery/main/public/icon-manifest.json';

    fetch(MANIFEST_URL)
      .then(function(res) { return res.json(); })
      .then(function(manifest) {
        var sets = Object.values(manifest.iconSets);
        if (sets.length === 0) throw new Error('No icon sets');
        var set = sets[Math.floor(Math.random() * sets.length)];
        var icon = set.icons[Math.floor(Math.random() * set.icons.length)];
        // cdnBase already includes commit SHA — fully immutable, no CDN cache issues
        link.href = icon.url;
      })
      .catch(function() {
        // Ultimate fallback — use a hardcoded reliable icon
        link.href = 'https://cdn.jsdelivr.net/gh/wangrui2025/sprites-gallery@main/public/favicons/msikma_pokesprite/pokemon-gen8/regular/pikachu.png';
      });
  })();
</script>
