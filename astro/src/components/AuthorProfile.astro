---
import { Image } from 'astro:assets';
import avatarImage from '../assets/avatar.png';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
/* FIXED: displayName - CN: 王锐 / EN: Rui Wang（王锐） */
const displayName = lang === 'en' ? 'Rui Wang（王锐）' : '王锐';
const title = lang === 'en' ? 'M.S. Candidate' : '硕士研究生';
const affiliation = lang === 'en' ? 'Shenzhen University' : '深圳大学';
---

<div class="author-profile">
  <div class="profile-avatar">
    <Image
      src={avatarImage}
      alt={displayName}
      width={256}
      height={256}
      format="webp"
      class="rounded-full w-32 h-32 mx-auto"
      loading="eager"
    />
  </div>
  <h2 class="author-name">{displayName}</h2>
  {/* FIXED: he/him - 英文固定，中英文版本均显示此文本 */}
  <p class="author-pronouns">he/him</p>
  <p class="author-title">{title}</p>
  <p class="author-affiliation">{affiliation}</p>

  <!-- PhD Application Status -->
  <div class="mb-4 text-center">
    <span class="inline-block px-3 py-1.5 rounded-full text-xs font-medium bg-gradient-to-r from-red-200 to-rose-200 dark:from-red-800/50 dark:to-rose-800/50 text-red-900 dark:text-red-100 border border-red-300 dark:border-red-600/50 shadow-sm">
      {lang === 'en' ? '🎓 Applying for PhD Programs · Fall 2027 Entry' : '🎓 申博中 · 2027 Fall 入学'}
    </span>
  </div>

  <!-- Primary Links: Email & GitHub -->
  <div class="author-links-primary">
    <a href="mailto:wr_szu@163.com" title={lang === 'zh' ? '邮箱（个人）' : 'Email (Personal)'} class="author-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="M22 6l-10 7L2 6"/>
      </svg>
      <span>wr_szu@163.com</span>
    </a>
    <a href="mailto:2400101058@mails.szu.edu.cn" title={lang === 'zh' ? '邮箱（学生）' : 'Email (Student)'} class="author-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="M22 6l-10 7L2 6"/>
      </svg>
      <span>2400101058@mails.szu.edu.cn</span>
    </a>
    <a href="https://github.com/wangrui2025" title="GitHub" class="author-link" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      <span>GitHub</span>
    </a>
  </div>

  <!-- Secondary Links -->
  <div class="author-links-secondary">
    <a href="https://scholar.google.com/citations?user=01amzbYAAAAJ" title="Google Scholar" class="author-link" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
      </svg>
    </a>
    <a href="https://orcid.org/0009-0001-0278-1985" title="ORCID" class="author-link" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M10 0H0v10h10V0zm14 0h-4v7h4V0zm-4 14h-4v10h4V14zm14-14h-4v7h4V0zm-4 14h-4v10h4V14z"/>
      </svg>
    </a>
    <a href="https://openreview.net/profile?id=%7ERui_Wang92" title="OpenReview" class="author-link" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
    </a>
    <a href="https://www.linkedin.com/in/wangrui2024/" title="LinkedIn" class="author-link" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
  </div>
</div>
