---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const displayName = lang === 'en' ? 'Rui Wang（王锐）' : '王锐';
const title = lang === 'en' ? 'M.S. Candidate' : '硕士研究生';
const affiliation = lang === 'en' ? 'Shenzhen University' : '深圳大学';
---

<div class="text-center p-5">
  <div class="mb-5 relative inline-block">
    <!-- Decorative ring behind avatar -->
    <div class="absolute inset-0 -m-2 rounded-full bg-gradient-to-br from-paper-accent/20 to-transparent dark:from-paper-accent-dark/20"></div>
    <Image
      src="/images/avatar.png"
      alt={displayName}
      width={256}
      height={256}
      class="rounded-full w-32 h-32 mx-auto relative ring-2 ring-border-primary/30 dark:ring-border-dark/30 shadow-lg"
      loading="eager"
      densities={[1, 2, 3]}
      sizes="128px"
      decoding="async"
    />
  </div>
  <h2 class="font-sans font-semibold text-[48px] leading-[1.1] text-heading-primary dark:text-heading-dark mb-2 tracking-tight">{displayName}</h2>
   <p class="text-sm text-text-primary/60 dark:text-text-dark/60 mb-2 tracking-wide">he/him</p>
  <p class="text-sm text-text-primary dark:text-text-dark mb-1 font-medium">{title}</p>
  <p class="text-sm text-text-secondary dark:text-text-secondary-dark mb-5">{affiliation}</p>

  <!-- Status -->
  <div class="mb-5 text-center flex flex-col gap-2">
    <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-medium bg-paper-accent dark:bg-paper-accent-dark text-paper-bg dark:text-paper-bg-dark shadow-sm">
      {lang === 'en' ? 'Seeking Internship / Applying for PhD (Fall 2027)' : '寻找实习 / 申博中 (2027 Fall)'}
    </span>
  </div>

  <!-- Social & Academic Links -->
  <div class="flex flex-wrap justify-center gap-2 p-4 rounded-2xl bg-paper-bg/50 dark:bg-paper-bg-dark/50 border border-border-primary/40 dark:border-border-dark/40 mb-2">
    <!-- Primary Links: Email & GitHub -->
    <a href="mailto:wr_szu@163.com" title={lang === 'zh' ? '邮箱（个人）' : 'Email (Personal)'} class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark text-xs transition-all duration-200 hover:border-link-primary dark:hover:border-link-dark hover:text-link-primary dark:hover:text-link-dark whitespace-nowrap no-underline">
      <Icon name="lucide:mail" class="w-4 h-4" />
      <span class="truncate max-w-[160px]">wr_szu@163.com</span>
    </a>
    <a href="mailto:2400101058@mails.szu.edu.cn" title={lang === 'zh' ? '邮箱（学生）' : 'Email (Student)'} class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark text-xs transition-all duration-200 hover:border-link-primary dark:hover:border-link-dark hover:text-link-primary dark:hover:text-link-dark whitespace-nowrap no-underline">
      <Icon name="lucide:mail" class="w-4 h-4" />
      <span class="truncate max-w-[200px]">2400101058@mails.szu.edu.cn</span>
    </a>
    <a href="https://github.com/wangrui2025" title="GitHub" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-link-primary dark:hover:text-link-dark hover:border-link-primary dark:hover:border-link-dark no-underline" target="_blank">
      <Icon name="simple-icons:github" class="w-5 h-5" />
    </a>

    <!-- Secondary Links: Icon-only -->
    <a href="https://scholar.google.com/citations?user=01amzbYAAAAJ" title="Google Scholar" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-brand-scholar hover:border-brand-scholar no-underline" target="_blank">
      <Icon name="scholar" class="w-5 h-5" />
    </a>
    <a href="https://orcid.org/0009-0001-0278-1985" title="ORCID" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-brand-orcid hover:border-brand-orcid no-underline" target="_blank">
      <Icon name="academicons:orcid" class="w-5 h-5" />
    </a>
    <a href="https://openreview.net/profile?id=%7ERui_Wang92" title="OpenReview" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-brand-openreview hover:border-brand-openreview no-underline" target="_blank">
      <Icon name="openreview" class="w-5 h-5" />
    </a>
    <a href="https://www.linkedin.com/in/wangrui2024/" title="LinkedIn" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-brand-linkedin hover:border-brand-linkedin no-underline" target="_blank">
      <Icon name="simple-icons:linkedin" class="w-5 h-5" />
    </a>
  </div>
</div>
