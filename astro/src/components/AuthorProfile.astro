---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import avatarImage from '../assets/avatar.png';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
/* FIXED: displayName - CN: 王锐 / EN: Rui Wang（王锐） */
const displayName = lang === 'en' ? 'Rui Wang（王锐）' : '王锐';
const title = lang === 'en' ? 'M.S. Candidate' : '硕士研究生';
const affiliation = lang === 'en' ? 'Shenzhen University' : '深圳大学';
---

<div class="text-center p-4">
  <div class="mb-4">
    <Image
      src={avatarImage}
      alt={displayName}
      width={256}
      height={256}
      format="webp"
      class="rounded-full w-32 h-32 mx-auto"
      loading="eager"
      densities={[1, 2, 3]}
      sizes="128px"
    />
  </div>
  <h2 class="text-xl font-semibold text-heading-primary dark:text-heading-dark mb-1">{displayName}</h2>
  {/* FIXED: he/him - 英文固定，中英文版本均显示此文本 */}
  <p class="text-sm text-text-primary/70 dark:text-text-dark/70 mb-1">he/him</p>
  <p class="text-sm text-text-primary dark:text-text-dark mb-1">{title}</p>
  <p class="text-sm text-text-primary dark:text-text-dark mb-4">{affiliation}</p>

  <!-- Status -->
  <div class="mb-4 text-center flex flex-col gap-2">
    <span class="inline-block px-3 py-1.5 rounded-full text-xs font-medium bg-gradient-to-r from-red-200 to-rose-200 dark:from-red-800/50 dark:to-rose-800/50 text-red-900 dark:text-red-100 border border-red-300 dark:border-red-600/50 shadow-sm">
      {lang === 'en' ? '🎓 Applying for PhD (Fall 2027)' : '🎓 申博中 (2027 Fall)'}
    </span>
  </div>

  <!-- Social & Academic Links -->
  <div class="flex flex-wrap justify-center gap-2 mb-4">
    <!-- Primary Links: Email & GitHub -->
    <a href="mailto:wr_szu@163.com" title={lang === 'zh' ? '邮箱（个人）' : 'Email (Personal)'} class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark text-xs transition-all duration-200 hover:border-link-primary dark:hover:border-link-dark hover:text-link-primary dark:hover:text-link-dark whitespace-nowrap no-underline">
      <Icon name="lucide:mail" class="w-4 h-4" />
      <span class="truncate max-w-[160px]">wr_szu@163.com</span>
    </a>
    <a href="mailto:2400101058@mails.szu.edu.cn" title={lang === 'zh' ? '邮箱（学生）' : 'Email (Student)'} class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark text-xs transition-all duration-200 hover:border-link-primary dark:hover:border-link-dark hover:text-link-primary dark:hover:text-link-dark whitespace-nowrap no-underline">
      <Icon name="lucide:mail" class="w-4 h-4" />
      <span class="truncate max-w-[200px]">2400101058@mails.szu.edu.cn</span>
    </a>
    <a href="https://github.com/wangrui2025" title="GitHub" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark text-xs transition-all duration-200 hover:border-link-primary dark:hover:border-link-dark hover:text-link-primary dark:hover:text-link-dark whitespace-nowrap no-underline" target="_blank">
      <Icon name="simple-icons:github" class="w-4 h-4" />
      <span>GitHub</span>
    </a>

    <!-- Secondary Links: Icon-only -->
    <a href="https://scholar.google.com/citations?user=01amzbYAAAAJ" title="Google Scholar" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-[#4A90E2] hover:border-[#4A90E2] no-underline" target="_blank">
      <Icon name="scholar" class="w-5 h-5" />
    </a>
    <a href="https://orcid.org/0009-0001-0278-1985" title="ORCID" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-[#A6B73F] hover:border-[#A6B73F] no-underline" target="_blank">
      <Icon name="academicons:orcid" class="w-5 h-5" />
    </a>
    <a href="https://openreview.net/profile?id=%7ERui_Wang92" title="OpenReview" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-[#2771B1] hover:border-[#2771B1] no-underline" target="_blank">
      <Icon name="openreview" class="w-5 h-5" />
    </a>
    <a href="https://www.linkedin.com/in/wangrui2024/" title="LinkedIn" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-primary dark:border-border-dark bg-paper-bg dark:bg-paper-bg-dark text-text-primary dark:text-text-dark transition-all duration-200 hover:text-[#0A66C2] hover:border-[#0A66C2] no-underline" target="_blank">
      <Icon name="simple-icons:linkedin" class="w-5 h-5" />
    </a>
  </div>
</div>
