---
import { navigation } from '../data/navigation';

export interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const langKey = lang === 'zh' ? 'zh' : 'en';
const navItems = navigation.main[langKey];
const switchUrl = lang === 'zh' ? '/' : '/zh/';
/* FIXED: switchLabel - CN: English / EN: 中文 */
const switchLabel = lang === 'zh' ? 'English' : '中文';
---

<div class="masthead">
  <div class="masthead__inner-wrap">
    <div class="masthead__menu">
      <nav id="site-nav" class="greedy-nav">
        <button aria-label={lang === 'zh' ? '切换导航' : 'Toggle navigation'} aria-expanded="false">
          <div class="navicon"></div>
        </button>
        <ul class="visible-links">
          <li class="masthead__menu-item masthead__menu-item--lg masthead__menu-home-item">
            <a href={lang === 'zh' ? '/zh/#about-me' : '/#about-me'}>
              {/* FIXED: 首页 / Homepage */}
              {lang === 'zh' ? '首页' : 'Homepage'}
            </a>
          </li>
          {navItems.map((item) => (
            <li class="masthead__menu-item">
              <a href={item.url}>{item.title}</a>
            </li>
          ))}
          <li class="masthead__menu-item">
            <a href={switchUrl}>{switchLabel}</a>
          </li>
        </ul>
        <ul class="hidden-links hidden"></ul>
      </nav>

      <button id="theme-toggle" class="theme-toggle p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label={lang === 'zh' ? '切换深色/浅色模式' : 'Toggle dark mode'} title={lang === 'zh' ? '切换深色/浅色模式' : 'Toggle dark/light mode'}>
        <!-- Sun icon: visible in light mode, hidden in dark mode -->
        <svg id="theme-toggle-sun" class="w-5 h-5 icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon icon: hidden in light mode, visible in dark mode -->
        <svg id="theme-toggle-moon" class="w-5 h-5 icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
