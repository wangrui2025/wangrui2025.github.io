---
import { navigation } from '../data/navigation';
import { Icon } from 'astro-icon/components';

export interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const langKey = lang === 'zh' ? 'zh' : 'en';
const navItems = navigation.main[langKey];
const switchUrl = lang === 'zh' ? '/' : '/zh/';
/* FIXED: switchLabel - CN: English / EN: 中文 */
const switchLabel = lang === 'zh' ? 'English' : '中文';
---

<div class="sticky top-0 z-50 bg-bg-primary dark:bg-bg-dark border-b border-border-primary dark:border-border-dark">
  <div class="max-w-[1200px] mx-auto px-4 py-2 flex items-center justify-between">
    <div class="flex items-center w-full justify-between max-md:flex-col max-md:items-start max-md:gap-2">
      <nav id="site-nav" class="flex items-center">
        <button aria-label={lang === 'zh' ? '切换导航' : 'Toggle navigation'} aria-expanded="false" class="hidden md:hidden">
          <div class="navicon"></div>
        </button>
        <ul class="flex list-none m-0 p-0 gap-6 max-md:flex-wrap max-md:gap-4">
          <li class="m-0 masthead__menu-item--lg masthead__menu-home-item">
            <a href={lang === 'zh' ? '/zh/#about-me' : '/#about-me'} data-astro-prefetch class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10">
              {/* FIXED: 首页 / Homepage */}
              {lang === 'zh' ? '首页' : 'Homepage'}
            </a>
          </li>
          {navItems.map((item) => (
            <li class="m-0">
              <a href={item.url} data-astro-prefetch class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10">{item.title}</a>
            </li>
          ))}
          <li class="m-0">
            <a href={switchUrl} data-astro-prefetch class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10">{switchLabel}</a>
          </li>
        </ul>
        <ul class="hidden md:hidden"></ul>
      </nav>

      <button id="theme-toggle" class="p-2 rounded-lg text-text-primary dark:text-text-dark hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label={lang === 'zh' ? '切换深色/浅色模式' : 'Toggle dark mode'} title={lang === 'zh' ? '切换深色/浅色模式' : 'Toggle dark/light mode'}>
        <!-- Sun icon: visible in light mode, hidden in dark mode -->
        <Icon id="theme-toggle-sun" name="lucide:sun" class="w-5 h-5 icon-sun" />
        <!-- Moon icon: hidden in light mode, visible in dark mode -->
        <Icon id="theme-toggle-moon" name="lucide:moon" class="w-5 h-5 icon-moon" />
      </button>
    </div>
  </div>
</div>
