---
import { navigation } from '../data/navigation';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const langKey = lang === 'zh' ? 'zh' : 'en';
const navItems = navigation.main[langKey];
const switchUrl = lang === 'zh' ? '/' : '/zh/';
const switchLabel = lang === 'zh' ? 'English' : '中文';
---

<div class="sticky top-0 z-50 bg-bg-primary dark:bg-bg-dark border-b border-border-primary dark:border-border-dark">
  <div class="max-w-[1200px] mx-auto px-4 py-2 flex items-center justify-between">
    <div class="flex items-center w-full justify-between max-md:flex-col max-md:items-start max-md:gap-2">
      <nav id="site-nav" class="flex items-center">
        <button aria-label={lang === 'zh' ? '切换导航' : 'Toggle navigation'} aria-expanded="false" class="hidden md:hidden">
          <div class="navicon"></div>
        </button>
        <ul class="flex list-none m-0 p-0 gap-6 max-md:flex-wrap max-md:gap-4">
          <li class="m-0 masthead__menu-item--lg masthead__menu-home-item">
            <a href={lang === 'zh' ? '/zh/#about-me' : '/#about-me'} class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10">
                {lang === 'zh' ? '首页' : 'Homepage'}
            </a>
          </li>
          {navItems.map((item) => (
            <li class="m-0">
              <a href={item.url} class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10">{item.title}</a>
            </li>
          ))}
          <li class="m-0">
            <a href={switchUrl} class="text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark hover:bg-black/5 dark:hover:bg-white/10" aria-label={lang === 'zh' ? 'Switch to English' : '切换到中文'}>{switchLabel}</a>
          </li>
        </ul>
        <ul class="hidden md:hidden"></ul>
      </nav>

      <ThemeToggle />
    </div>
  </div>
</div>
