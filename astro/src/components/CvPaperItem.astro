---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  paper: CollectionEntry<'papers'>;
  lang: 'en' | 'zh';
}

const { paper, lang } = Astro.props;
const localized = paper.data[lang];

// Separator and asterisk based on language
const sep = lang === 'zh' ? '，' : ', ';
const corrSuffix = '*';
---

<div class="cv-pub-entry">
  <div class="cv-pub-venue">[{paper.data.venue}]</div>
  <div class="cv-pub-main">
    <div class="cv-pub-title">{localized.title}</div>
    <div class="cv-pub-authors">
      {localized.authors.map((author, i) => (
        <span class={author.is_self ? 'author-self' : 'author-other'}>{author.name}{author.is_corresponding ? corrSuffix : ''}{i < localized.authors.length - 1 ? sep : ''}</span>
      ))}
    </div>
    <div class="cv-pub-links">
      {paper.data.arxiv && (
        <a href={paper.data.arxiv} target="_blank" rel="noopener" class="pub-link">
          [arXiv]
        </a>
      )}
      {paper.data.project && (
        <a href={paper.data.project} target="_blank" rel="noopener" class="pub-link">
          [Project]
        </a>
      )}
    </div>
  </div>
</div>

<style>
  /* Hanging layout (悬挂式布局) - venue as left-anchored marginalia */
  .cv-pub-entry {
    position: relative;
    padding-left: 55pt;
    margin-bottom: 6pt;
  }

  .cv-pub-venue {
    position: absolute;
    left: 0;
    top: 0;
    width: 52pt;
    font-size: 8.5pt;
    color: #555;
    font-weight: 700;
    word-break: break-word;
    text-align: right;
  }

  .cv-pub-main {
    display: flex;
    flex-direction: column;
    gap: 1pt;
  }

  .cv-pub-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  .cv-pub-authors {
    font-size: 9pt;
    line-height: 1.4;
  }

  .cv-pub-links {
    display: flex;
    gap: 8pt;
    margin-top: 1pt;
  }

  .author-self {
    color: #1a1a1a;
  }

  .author-other {
    font-weight: 400;
    color: #666;
  }

  .pub-link {
    font-size: 8.5pt;
    color: #444;
    text-decoration: none;
  }

  .pub-link:hover {
    color: #1a1a1a;
    text-decoration: underline;
  }
</style>
