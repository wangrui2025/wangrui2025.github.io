---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  paper: CollectionEntry<'papers'>;
  lang: 'en' | 'zh';
}

const { paper, lang } = Astro.props;
const localized = paper.data[lang];

// Separator and asterisk based on language
const sep = lang === 'zh' ? '，' : ', ';
const corrSuffix = '*';
---

<div class="relative pl-[55pt] mb-1.5">
  <div class="absolute left-0 top-0 w-[52pt] text-[8.5pt] text-[#5e5d59] dark:text-[#87867f] font-bold break-words text-right">
    [{paper.data.venue}]
  </div>
  <div class="flex flex-col gap-0.5">
    <div class="font-semibold text-[11pt] leading-tight text-heading-primary dark:text-heading-dark">
      {localized.title}
    </div>
    <div class="text-[9pt] leading-tight">
      {localized.authors.map((author, i) => (
        <span class="text-[#1a1a1a]">
          {author.name}{author.is_corresponding ? corrSuffix : ''}{i < localized.authors.length - 1 ? sep : ''}
        </span>
      ))}
    </div>
    <div class="flex gap-2 mt-0.5">
      {paper.data.arxiv && (
        <a href={paper.data.arxiv} target="_blank" rel="noopener" class="text-[8.5pt] text-[#5e5d59] dark:text-[#87867f] no-underline hover:text-heading-primary dark:hover:text-heading-dark hover:underline">
          [arXiv]
        </a>
      )}
      {paper.data.project && (
        <a href={paper.data.project} target="_blank" rel="noopener" class="text-[8.5pt] text-[#5e5d59] dark:text-[#87867f] no-underline hover:text-heading-primary dark:hover:text-heading-dark hover:underline">
          [Project]
        </a>
      )}
    </div>
  </div>
</div>
