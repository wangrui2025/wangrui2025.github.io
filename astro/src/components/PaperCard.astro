---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { getEntry, type CollectionEntry } from 'astro:content';
import osaImage from '../assets/paper/fig_osu_page-0001.jpg';
import gdkvmImage from '../assets/paper/fig_gdkvm_page-0001.jpg';

// Image path → imported image mapping (required for astro:assets <Image />)
const imageMap = {
  '../assets/paper/fig_osu_page-0001.jpg': osaImage,
  '../assets/paper/fig_gdkvm_page-0001.jpg': gdkvmImage,
} as const;

export interface Props {
  paperKey?: 'osa' | 'gdkvm';
  paper?: CollectionEntry<'papers'>;
  lang?: 'en' | 'zh';
}

const { paperKey, paper: paperEntry, lang = 'en' } = Astro.props;

// Support both direct paper prop (from getCollection) and paperKey (backwards compat)
const paper = paperEntry ?? (paperKey ? await getEntry('papers', paperKey) : null);

if (!paper) {
  throw new Error('Paper not found: provide either paper or paperKey prop');
}

const localized = paper.data[lang];
const image = imageMap[paper.data.image as keyof typeof imageMap];

// Tag URL mapping
const tagUrls: Record<string, string> = {
  'csranking': 'https://csrankings.org/#/index?vision&world',
  'CCF-A': 'https://www.ccf.org.cn/Academic_Evaluation/By_category/',
};
---

<div class="paper-box">
  <div class="paper-box-image">
    {image && (
      <Image
        src={image}
        alt={lang === 'zh' ? paper.data.alt_zh : paper.data.alt_en}
        width={600}
        height={300}
        format="webp"
        loading="lazy"
        class="w-full h-auto rounded"
      />
    )}
  </div>
  <div class="paper-box-text">
    <h3>
      <span>{localized.title}</span>
    </h3>
    <p class="paper-authors">
      {localized.authors.map((author, i) => (
        <>
          <span class={author.is_self ? 'author-self' : ''}>{author.name}{author.is_corresponding ? '*' : ''}</span>
          {i < localized.authors.length - 1 && <span class="author-sep">{lang === 'zh' ? '，' : ', '}</span>}
        </>
      ))}
    </p>
    <p class="paper-meta">
      <strong>{paper.data.venue_full}</strong>
      {paper.data.tags && paper.data.tags.map((tag) => (
        tagUrls[tag] ? (
          <a href={tagUrls[tag]} class="paper-venue-tag" target="_blank" rel="noopener noreferrer">{tag}</a>
        ) : (
          <span class="paper-venue-tag">{tag}</span>
        )
      ))}
    </p>
    <div class="paper-keywords">
      {localized.technologies?.map((tech) => (
        <span class="tag tag-tech">{tech}</span>
      ))}
      {localized.fields?.map((field) => (
        <span class="tag tag-field">{field}</span>
      ))}
    </div>
    <div class="paper-links">
      {paper.data.project && (
        <a href={paper.data.project} class="paper-link" title={lang === 'zh' ? '项目主页' : 'Project Page'}>
          🏠 {lang === 'zh' ? '项目' : 'Project'}
        </a>
      )}
      {paper.data.arxiv && (
        <a href={paper.data.arxiv} class="paper-link paper-link-arxiv" title={lang === 'zh' ? '论文预印本' : 'arXiv'}>
          <Icon name="simple-icons:arxiv" class="w-4 h-4" />
          arXiv
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .paper-link-arxiv {
    background: transparent;
    color: #b31b1b;
    border: 1px solid #b31b1b;
  }

  .paper-link-arxiv:hover {
    background: #b31b1b;
    color: white;
    opacity: 1;
    transform: translateY(-2px);
    text-decoration: none;
  }

  :global(.dark) .paper-link-arxiv {
    color: #ff6b6b;
    border-color: #ff6b6b;
  }

  :global(.dark) .paper-link-arxiv:hover {
    background: #ff6b6b;
    color: #1a1a1a;
  }

  .paper-venue-tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: var(--paper-accent);
    color: var(--paper-bg);
    opacity: 0.5;
    font-weight: 500;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  :global(.tag-field) {
    opacity: 0.5;
  }

  :global(.tag-tech) {
    opacity: 0.75;
  }

  .author-self {
    font-weight: 600;
  }

  .author-sep {
    color: #999;
  }
</style>
