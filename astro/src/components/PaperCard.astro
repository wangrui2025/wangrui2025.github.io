---
import { Image } from 'astro:assets';
import { getEntry, type CollectionEntry } from 'astro:content';
import { TAG_URLS } from '../utils/constants';

import osaImage from '../assets/paper/fig_osu_page-0001.jpg';
import gdkvmImage from '../assets/paper/fig_gdkvm_page-0001.jpg';

const imageMap = {
  'fig_osu_page-0001.jpg': osaImage,
  'fig_gdkvm_page-0001.jpg': gdkvmImage,
} as const;

export interface Props {
  paperKey?: 'osa' | 'gdkvm';
  paper?: CollectionEntry<'papers'>;
  lang?: 'en' | 'zh';
}

const { paperKey, paper: paperEntry, lang = 'en' } = Astro.props;

// Support both direct paper prop (from getCollection) and paperKey (backwards compat)
const paper = paperEntry ?? (paperKey ? await getEntry('papers', paperKey) : null);

if (!paper) {
  throw new Error('Paper not found: provide either paper or paperKey prop');
}

const localized = paper.data[lang];
const imageSrc = imageMap[paper.data.image.split('/').pop() as keyof typeof imageMap];
---

<div class="flex flex-col border border-paper-border dark:border-paper-border-dark rounded-xl p-5 mb-6 bg-paper-bg dark:bg-paper-bg-dark border-l-4 border-l-paper-accent dark:border-l-paper-accent-dark shadow-sm transition-all duration-200 hover:shadow-md hover:-translate-y-0.5">
  <div class="flex justify-center w-full mb-4">
    {imageSrc && (
      <Image
        src={imageSrc}
        alt={lang === 'zh' ? paper.data.alt_zh : paper.data.alt_en}
        width={600}
        height={300}
        format="webp"
        loading="lazy"
        class="w-full max-w-[350px] h-auto rounded-lg border border-paper-border dark:border-paper-border-dark shadow-md"
        densities={[1, 2]}
        sizes="(max-width: 768px) 100vw, 400px"
      />
    )}
  </div>
  <div class="w-full">
    <h3 class="font-semibold text-[1.3rem] leading-tight mb-2">
      <span class="text-paper-accent dark:text-paper-accent-dark">{localized.title}</span>
    </h3>
    <p class="text-sm text-text-secondary dark:text-text-secondary-dark mb-3">
      {localized.authors.map((author, i) => (
        <>
          <span class={author.is_self ? 'font-semibold' : ''}>{author.name}{author.is_corresponding ? '*' : ''}</span>
          {i < localized.authors.length - 1 && <span class="text-text-secondary dark:text-text-secondary-dark">{lang === 'zh' ? '，' : ', '}</span>}
        </>
      ))}
    </p>
    <p class="text-sm text-text-secondary dark:text-text-secondary-dark mb-2 tabular-nums">
      <strong class="text-text-primary dark:text-text-dark">{paper.data.venue_full}</strong>
      {paper.data.tags && paper.data.tags.map((tag) => (
        TAG_URLS[tag] ? (
          <a href={TAG_URLS[tag]} class="inline-block text-[0.7rem] px-2 py-0.5 rounded bg-paper-accent dark:bg-paper-accent-dark text-paper-bg dark:text-paper-bg-dark font-medium ml-2 align-middle hover:opacity-80 no-underline" target="_blank" rel="noopener noreferrer">{tag}</a>
        ) : (
          <span class="inline-block text-[0.7rem] px-2 py-0.5 rounded bg-paper-accent dark:bg-paper-accent-dark text-paper-bg dark:text-paper-bg-dark font-medium ml-2 align-middle">{tag}</span>
        )
      ))}
    </p>
    <div class="flex flex-wrap gap-1.5 mb-3">
      {localized.technologies?.map((tech) => (
        <span class="inline-block px-2 py-0.5 text-xs rounded font-medium bg-tag-tech-bg dark:bg-tag-tech-bg-dark text-tag-tech-text dark:text-tag-tech-text-dark">{tech}</span>
      ))}
      {localized.fields?.map((field) => (
        <span class="inline-block px-2 py-0.5 text-xs rounded font-medium bg-tag-field-bg dark:bg-tag-field-bg-dark text-tag-field-text dark:text-tag-field-text-dark">{field}</span>
      ))}
    </div>
    <div class="flex gap-4 mt-3">
      {paper.data.project && (
        <a href={paper.data.project} target="_blank" rel="noopener" class="text-sm text-paper-accent dark:text-paper-accent-dark no-underline hover:underline" title={lang === 'zh' ? '项目主页' : 'Project Page'}>
          [Project]
        </a>
      )}
      {paper.data.arxiv && (
        <a href={paper.data.arxiv} target="_blank" rel="noopener" class="text-sm text-paper-accent dark:text-paper-accent-dark no-underline hover:underline" title={lang === 'zh' ? '论文预印本' : 'arXiv'}>
          [arXiv]
        </a>
      )}
    </div>
  </div>
</div>
