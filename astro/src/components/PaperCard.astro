---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import osaImage from '../assets/paper/fig_osu_page-0001.jpg';
import gdkvmImage from '../assets/paper/fig_gdkvm_page-0001.jpg';

// Image path → imported image mapping (required for astro:assets <Image />)
const imageMap = {
  '../assets/paper/fig_osu_page-0001.jpg': osaImage,
  '../assets/paper/fig_gdkvm_page-0001.jpg': gdkvmImage,
} as const;

export interface Props {
  paperKey: 'osa' | 'gdkvm';
  lang?: 'en' | 'zh';
}

const { paperKey, lang = 'en' } = Astro.props;
const paper = await getEntry('papers', paperKey);

if (!paper) {
  throw new Error(`Paper not found: ${paperKey}`);
}

const localized = paper.data[lang];
const image = imageMap[paper.data.image as keyof typeof imageMap];
---

<div class="paper-box">
  <div class="paper-box-image">
    {image && (
      <Image
        src={image}
        alt={lang === 'zh' ? paper.data.alt_zh : paper.data.alt_en}
        width={600}
        height={300}
        format="webp"
        loading="lazy"
        class="w-full h-auto rounded"
      />
    )}
  </div>
  <div class="paper-box-text">
    <h3>
      <span>{localized.title}</span>
    </h3>
    <p class="paper-authors">{localized.authors}</p>
    <p class="paper-meta">
      <strong>{paper.data.venue_full}</strong>
    </p>
    <div class="paper-keywords">
      {localized.technologies?.map((tech) => (
        <span class="tag tag-tech">{tech}</span>
      ))}
      {localized.fields?.map((field) => (
        <span class="tag tag-field">{field}</span>
      ))}
    </div>
    <div class="paper-links">
      {paper.data.project && (
        <a href={paper.data.project} class="paper-link" title={lang === 'zh' ? '项目主页' : 'Project Page'}>
          🏠 {lang === 'zh' ? '项目' : 'Project'}
        </a>
      )}
      {paper.data.arxiv && (
        <a href={paper.data.arxiv} class="paper-link !bg-[#b31b1b]" title={lang === 'zh' ? '论文预印本' : 'arXiv'}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M14 13.5H2V2.5h12v11zm0-10H2V12h12V3.5zM4 4h8v1H4V4zm0 2h8v1H4V6zm0 2h5v1H4V8z"/>
          </svg>
          arXiv
        </a>
      )}
    </div>
  </div>
</div>
