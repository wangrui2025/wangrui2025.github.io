---
interface Props {
  university: { zh: string; en: string };
  universityUrl?: { zh: string; en: string };
  major: { zh: string; en: string };
  degree: { zh: string; en: string };
  period: { zh: string; en: string };
  detail?: { zh: string; en: string };
  examScores?: { zh: string; en: string };
  lang: 'en' | 'zh';
}

const {
  university,
  universityUrl,
  major,
  degree,
  period,
  detail,
  examScores,
  lang,
} = Astro.props;

const displayUniversity = university[lang];
const displayMajor = major[lang];
const displayPeriod = period[lang];
const displayDetail = detail?.[lang];
const displayExamScores = examScores?.[lang];
---

<div>
  <div class="flex justify-between items-baseline gap-2">
    <span>
      {universityUrl?.[lang] ? (
        <a href={universityUrl[lang]} target="_blank" rel="noopener" class="text-inherit no-underline border-b border-current hover:opacity-70 transition-opacity">
          {displayUniversity}
        </a>
      ) : (
        displayUniversity
      )}
    </span>
    <span class="text-sm text-text-primary/60 dark:text-text-dark/60 tabular-nums">{displayPeriod}</span>
  </div>
  <div class="text-text-primary/80 dark:text-text-dark/80">{displayMajor} · {degree[lang]}</div>
  {displayDetail && (
    <div class="text-text-primary dark:text-text-dark">
      {displayDetail.split('·').map((part: string, i: number) => (
        <>
          {i > 0 && <span class="text-link-primary font-semibold">·</span>}
          <span class={i === 0 ? 'font-semibold' : ''}>{part.trim()}</span>
        </>
      ))}
    </div>
  )}
  {displayExamScores && <div class="text-text-primary dark:text-text-dark">{displayExamScores}</div>}
</div>
