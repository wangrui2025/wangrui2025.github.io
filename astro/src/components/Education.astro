---
import { education } from '../data/education';

export interface Props {
  type: 'master' | 'bachelor';
  lang?: 'en' | 'zh';
}

const { type, lang = 'en' } = Astro.props;
const edu = education[type];
---

<div class="education-entry mb-6 p-4 border border-[var(--paper-border)] rounded-xl bg-[var(--paper-bg)] shadow-sm">
  <p class="text-primary flex flex-wrap gap-1">
    <span class="flex-1">{edu.description[lang]}</span>
    <span class="period whitespace-nowrap">{edu.period[lang]}</span>
  </p>
</div>
