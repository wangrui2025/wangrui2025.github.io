---
import { getEntry } from 'astro:content';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const edu = await getEntry('education', 'education');
if (!edu) throw new Error('Education entry not found');
const educationData = edu.data;
const entries = [educationData.master, educationData.bachelor];
---

<div class="flex flex-col gap-3">
  {entries.map((entry) => (
    <div class="bg-paper-bg dark:bg-paper-bg-dark border border-paper-border dark:border-paper-border-dark rounded-xl p-3.5 shadow-sm flex flex-col gap-1 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5">
      <div class="flex items-baseline justify-between gap-2 flex-wrap">
        <div class="flex items-baseline gap-2 flex-wrap">
          <a href={entry.universityUrl[lang]} target="_blank" rel="noopener" class="font-semibold text-lg text-heading-primary dark:text-heading-dark hover:text-link-primary dark:hover:text-link-dark transition-colors no-underline">
            {entry.university[lang]}
          </a>
          <span class="text-xs text-text-secondary dark:text-text-secondary-dark whitespace-nowrap tabular-nums">{entry.period[lang]}</span>
        </div>
      </div>
      <div class="flex flex-col gap-0.5">
        <a href={entry.collegeUrl[lang]} target="_blank" rel="noopener" class="text-sm text-text-primary dark:text-text-dark hover:text-link-primary dark:hover:text-link-dark transition-colors no-underline">
          {entry.college[lang]}
        </a>
        <div class="flex items-center gap-3 flex-wrap mt-0.5">
          <span class="text-sm text-text-secondary dark:text-text-secondary-dark">{entry.major[lang]}</span>
          <span class="text-sm text-text-secondary dark:text-text-secondary-dark">{entry.degree[lang]}</span>
        </div>
      </div>
    </div>
  ))}
</div>
