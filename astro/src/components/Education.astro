---
import { education } from '../data/education';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
---

<table class="education-table w-full text-sm text-[var(--text-color)]">
  <tbody class="divide-y divide-[var(--paper-border)]">
    <tr>
      <td class="py-3 pr-4 align-top">{education.master.school[lang]}</td>
      <td class="py-3 pr-4 align-top min-w-[14rem]">{education.master.major[lang]}</td>
      <td class="py-3 pr-4 align-top min-w-[5rem] text-[var(--text-secondary)]">{education.master.degree[lang]}</td>
      <td class="py-3 align-top whitespace-nowrap text-[var(--text-secondary)] text-right">{education.master.period[lang]}</td>
    </tr>
    <tr>
      <td class="py-3 pr-4 align-top">{education.bachelor.school[lang]}</td>
      <td class="py-3 pr-4 align-top min-w-[14rem]">{education.bachelor.major[lang]}</td>
      <td class="py-3 pr-4 align-top min-w-[5rem] text-[var(--text-secondary)]">{education.bachelor.degree[lang]}</td>
      <td class="py-3 align-top whitespace-nowrap text-[var(--text-secondary)] text-right">{education.bachelor.period[lang]}</td>
    </tr>
  </tbody>
</table>
