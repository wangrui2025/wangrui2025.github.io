---
import { Icon } from 'astro-icon/components';

interface Props {
  citations: number;
}
const { citations } = Astro.props;
---

<a
  href="https://scholar.google.com/citations?user=01amzbYAAAAJ"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center overflow-hidden rounded-md border border-border-primary dark:border-border-dark font-sans text-[11px] leading-none transition-transform hover:scale-[1.02] active:scale-95"
>
  <!-- Left: Icon and text -->
  <span class="flex items-center px-2 py-1.5 border-r border-border-primary dark:border-border-dark bg-scholar-badge-bg dark:bg-scholar-badge-bg-dark text-scholar-badge-text dark:text-scholar-badge-text-dark">
    <Icon class="mr-1.5 h-3 w-3 fill-scholar-icon" name="scholar" />
    Google Scholar
  </span>
  <!-- Right: citations count -->
  <span class="px-2 py-1.5 font-bold bg-paper-bg dark:bg-paper-bg-dark text-scholar-icon">
    citations {citations}
  </span>
</a>
