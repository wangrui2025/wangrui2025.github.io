---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CV - Rui Wang"
  description="Curriculum Vitae of Rui Wang"
  lang="en"
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">王锐</h1>
      <h2 class="cv-name-en">Rui Wang</h2>
      <div class="cv-contact">
        <span>15938550910</span>
        <span class="sep">丨</span>
        <span>wangrui</span>
        <span class="sep">丨</span>
        <span>Shenzhen, China</span>
      </div>
      <div class="cv-meta">
        <span>2001-10</span>
        <span class="sep">丨</span>
        <span>Male</span>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title">教育经历 Education</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">深圳大学</span>
          <span class="cv-entry-period">2024.09 - 2027.06 (Expected)</span>
        </div>
        <div class="cv-entry-sub">M.S. in Computer Science · College of Computer Science and Software Engineering</div>
        <div class="cv-entry-detail">Supervisor: Prof. Huisi Wu · Research: Echocardiography Video Segmentation</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">河南大学</span>
          <span class="cv-entry-period">2020.09 - 2024.06</span>
        </div>
        <div class="cv-entry-sub">B.S. in Data Science and Big Data Technology · School of Computer and Information Engineering</div>
        <div class="cv-entry-detail">Kaifeng | GPA: 3.45/4.00 | Rank: 15/128 (Top 11%) | CET-4: 548 | CET-6: 435</div>
      </div>
    </section>

    <!-- Publications -->
    <section class="cv-section">
      <h2 class="cv-section-title">发表论文 Publications</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">OSA: Orthogonal State Update with Anatomical Prior-aware Feature Enhancement for Echocardiography Video Segmentation</span>
          <span class="cv-entry-period">CVPR 2026</span>
        </div>
        <div class="cv-entry-sub">Rui Wang, Huisi Wu, et al.</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">GDKVM: Gated Delta Rule-based Spatio-Temporal Key-Value Memory for Echocardiography Video Segmentation</span>
          <span class="cv-entry-period">ICCV 2025</span>
        </div>
        <div class="cv-entry-sub">Rui Wang, Huisi Wu, et al.</div>
      </div>
    </section>

    <!-- Research Directions -->
    <section class="cv-section">
      <h2 class="cv-section-title">研究方向 Research Directions</h2>
      <div class="cv-grid-2">
        <div>• Efficient NN Architectures</div>
        <div>• Non-convex Optimization / Geometric DL</div>
        <div>• Long-range Dependencies in CV</div>
        <div>• Large-scale Multimodal Pretraining</div>
        <div>• Inference-time Efficiency for VLMs</div>
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title">荣誉奖项 Honors & Awards</h2>
      <div class="cv-grid">
        <div class="cv-grid-item"><span>National Graduate Scholarship (国家奖学金)</span><span class="right">2025.12</span></div>
        <div class="cv-grid-item"><span>SZU Graduate Academic Scholarship — First Prize (一等奖)</span><span class="right">2025.12</span></div>
        <div class="cv-grid-item"><span>SZU Graduate Academic Scholarship — Special Prize (特等奖)</span><span class="right">2024.12</span></div>
        <div class="cv-grid-item"><span>SZU Academic Launch Scholarship (学术启航奖学金)</span><span class="right">2026.01</span></div>
        <div class="cv-grid-item"><span>Henan University Merit Student & Scholarship (河南大学三好学生及奖学金)</span><span class="right">2022.12</span></div>
        <div class="cv-grid-item"><span>CCF-CSP Certification — 170 pts (Top 28%)</span><span class="right">2022.03</span></div>
        <div class="cv-grid-item"><span>13th LanQiao Cup C/C++ Programming — Provincial 3rd Prize</span><span class="right">2022.05</span></div>
        <div class="cv-grid-item"><span>16th China University Computer Design Competition — Provincial 3rd Prize</span><span class="right">2023.05</span></div>
        <div class="cv-grid-item"><span>16th "Challenge Cup" — Provincial 3rd Prize</span><span class="right">2023.08</span></div>
        <div class="cv-grid-item"><span>9th China "Internet+" Innovation Competition — Provincial 3rd Prize</span><span class="right">2023.08</span></div>
      </div>
    </section>

    <!-- Project -->
    <section class="cv-section">
      <h2 class="cv-section-title">项目经历 Project Experience</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">how2research</span>
          <span class="cv-entry-period">Open Source</span>
        </div>
        <div class="cv-entry-sub">An open-source research guide for graduate students</div>
        <div class="cv-entry-detail">Covers CVPR/ICCV submission processes, efficient LaTeX writing tips, research prompt engineering, and development environment setup (uv, VSCode). Maintained under "miyuki11".</div>
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title">个人技能 Skills</h2>
      <div class="cv-grid-2">
        <div><span class="skill-label">Programming:</span> Python, C/C++, SQL, JavaScript</div>
        <div><span class="skill-label">Deep Learning:</span> PyTorch, TensorFlow, Medical Image Analysis</div>
        <div><span class="skill-label">Tools:</span> Git, Linux, Docker, VS Code, PyCharm</div>
        <div><span class="skill-label">Research:</span> Claude Code, Harness Engineering, LaTeX</div>
      </div>
    </section>

    <!-- Hobbies -->
    <section class="cv-section">
      <h2 class="cv-section-title">兴趣特长 Hobbies</h2>
      <div class="cv-hobbies">
        <span>Volleyball</span>
        <span class="sep-dot">·</span>
        <span>Baseball / Softball</span>
        <span class="sep-dot">·</span>
        <span>Calligraphy</span>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  /* A4: 210mm x 297mm */
  .cv-page {
    font-family: 'Times New Roman', 'Noto Serif SC', serif;
    font-size: 10pt;
    line-height: 1.35;
    width: 210mm;
    min-height: 297mm;
    max-width: 210mm;
    margin: 0 auto;
    padding: 15mm 20mm;
    background: white;
    color: #1a1a1a;
    box-sizing: border-box;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 12pt;
    padding-bottom: 8pt;
    border-bottom: 1.5pt solid #1a1a1a;
  }

  .cv-name {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: 3pt;
    margin: 0 0 2pt 0;
  }

  .cv-name-en {
    font-size: 11pt;
    font-weight: 400;
    letter-spacing: 1pt;
    margin: 0 0 6pt 0;
    color: #555;
  }

  .cv-contact,
  .cv-meta {
    font-size: 9pt;
    color: #444;
    margin-bottom: 2pt;
  }

  .sep {
    margin: 0 6pt;
    color: #999;
  }

  .cv-section {
    margin-bottom: 9pt;
  }

  .cv-section-title {
    font-size: 10.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: 5pt;
    padding-bottom: 2pt;
    border-bottom: 0.75pt solid #1a1a1a;
  }

  .cv-entry {
    margin-bottom: 5pt;
  }

  .cv-entry:last-child {
    margin-bottom: 0;
  }

  .cv-entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 6pt;
  }

  .cv-entry-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
  }

  .cv-entry-period {
    font-size: 9pt;
    color: #666;
    flex-shrink: 0;
  }

  .cv-entry-sub {
    font-size: 9pt;
    color: #444;
    margin-top: 1pt;
  }

  .cv-entry-detail {
    font-size: 8.5pt;
    color: #666;
    margin-top: 1pt;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2pt 8pt;
  }

  .cv-grid-item {
    display: contents;
  }

  .cv-grid-item > span:first-child {
    font-size: 9pt;
  }

  .cv-grid-item .right {
    font-size: 9pt;
    color: #666;
    text-align: right;
    flex-shrink: 0;
  }

  .cv-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2pt 12pt;
    font-size: 9pt;
  }

  .skill-label {
    font-weight: 600;
  }

  .cv-hobbies {
    font-size: 9pt;
    color: #444;
  }

  .sep-dot {
    margin: 0 6pt;
    color: #999;
  }
</style>
