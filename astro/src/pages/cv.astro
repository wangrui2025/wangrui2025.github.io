---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CV - Rui Wang"
  description="Curriculum Vitae of Rui Wang"
  lang="en"
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">王锐</h1>
      <div class="cv-contact">
        <span>15938550910</span>
        <span class="sep">丨</span>
        <span>wangrui</span>
        <span class="sep">丨</span>
        <span>2001-10</span>
        <span class="sep">丨</span>
        <span>男</span>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title">教育经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">河南大学</span>
          <span class="cv-entry-period">2020.09 - 2024.06</span>
        </div>
        <div class="cv-entry-sub">数据科学与大数据技术 本科 · 计算机与信息工程学院 · 开封</div>
        <div class="cv-entry-detail">学业成绩：86.45 | GPA：3.45/4.00 | 专业排名 15/128 (前11%) | CET-4: 548 | CET-6: 435</div>
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title">荣誉奖项</h2>
      <div class="cv-grid">
        <div class="cv-grid-item"><span>CCF-CSP认证 - 170分（前28%）</span><span class="right">2022.03</span></div>
        <div class="cv-grid-item"><span>第十三届蓝桥杯C/C++程序设计组 - 省三等奖</span><span class="right">2022.05</span></div>
        <div class="cv-grid-item"><span>第四届 全国大学生算法设计与编程挑战赛(秋季赛) - 铜奖</span><span class="right">2022.05</span></div>
        <div class="cv-grid-item"><span>第十六届中国大学生计算机设计大赛河南省 - 省三等奖</span><span class="right">2023.05</span></div>
        <div class="cv-grid-item"><span>第十六届"挑战杯"大学生课外学术科技作品竞赛 - 省三等奖</span><span class="right">2023.08</span></div>
        <div class="cv-grid-item"><span>第九届 中国"互联网＋"大学生创新创业大赛 - 省三等奖</span><span class="right">2023.08</span></div>
        <div class="cv-grid-item"><span>河南大学奖学金 & 河南大学三好学生</span><span class="right">2022.12</span></div>
        <div class="cv-grid-item"><span>"高教社杯"全国商务英语实践大赛 - 一等奖</span><span class="right">2022.11</span></div>
        <div class="cv-grid-item"><span>《英语周报》杯全国大学生英语语法挑战赛A组 - 一等奖</span><span class="right">2022.11</span></div>
      </div>
    </section>

    <!-- Experience -->
    <section class="cv-section">
      <h2 class="cv-section-title">实践经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">河南大学22号院社区疫情防控工作</span>
          <span class="cv-entry-period">2022.08 - 2022.09</span>
        </div>
        <div class="cv-entry-sub">志愿者</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">河南大学2022年"河大杯"男排比赛</span>
        </div>
        <div class="cv-entry-sub">第一名 & 优秀运动员</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">"青春健康教育暨艾滋病预防知识"宣传服务活动</span>
          <span class="cv-entry-period">2022.05</span>
        </div>
        <div class="cv-entry-sub">先进个人</div>
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title">个人技能</h2>
      <div class="cv-skills-grid">
        <div><span class="skill-label">编程语言：</span>Python, C/C++, SQL, JavaScript</div>
        <div><span class="skill-label">深度学习：</span>PyTorch, TensorFlow, 医学影像分析, 视频理解</div>
        <div><span class="skill-label">开发工具：</span>Git, Linux, Docker, VS Code, PyCharm</div>
        <div><span class="skill-label">英语能力：</span>CET-6 (435分)，良好的英文文献阅读与写作能力</div>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .cv-page {
    font-family: 'Times New Roman', 'Noto Serif SC', serif;
    font-size: 11px;
    line-height: 1.4;
    max-width: 680px;
    margin: 0 auto;
    padding: 32px 24px;
    background: white;
    color: #333;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1.5px solid #333;
  }

  .cv-name {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 4px;
    margin-bottom: 6px;
  }

  .cv-contact {
    font-size: 10px;
    color: #555;
  }

  .sep {
    margin: 0 6px;
    color: #999;
  }

  .cv-section {
    margin-bottom: 12px;
  }

  .cv-section-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    padding-bottom: 2px;
    border-bottom: 0.5px solid #999;
  }

  .cv-entry {
    margin-bottom: 5px;
  }

  .cv-entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .cv-entry-title {
    font-weight: 600;
    font-size: 11px;
  }

  .cv-entry-period {
    font-size: 10px;
    color: #666;
    flex-shrink: 0;
  }

  .cv-entry-sub {
    font-size: 10px;
    color: #555;
  }

  .cv-entry-detail {
    font-size: 10px;
    color: #666;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2px 8px;
  }

  .cv-grid-item {
    display: contents;
    font-size: 10px;
  }

  .cv-grid-item span:first-child {
    font-size: 10px;
  }

  .cv-grid-item .right {
    font-size: 10px;
    color: #666;
    text-align: right;
    flex-shrink: 0;
  }

  .cv-skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 16px;
    font-size: 10px;
  }

  .skill-label {
    font-weight: 600;
  }
</style>
