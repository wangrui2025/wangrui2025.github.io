---
import BaseLayout from '../layouts/BaseLayout.astro';
import Favicon from '../components/Favicon.astro';

const title = 'Design System — Rui Wang';
const description = 'wangrui2025.github.io 的设计决策与实现备忘';
---

<BaseLayout title={title} description={description} lang="en" fixedFavicon>

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-6 py-32">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-5 bg-[var(--color-paper-accent)] blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-64 h-64 rounded-full opacity-5 bg-[var(--color-scholar-icon)] blur-3xl"></div>
    </div>
    <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-6">Design System</p>
    <h1 class="text-5xl md:text-6xl font-bold font-serif text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-6 leading-tight">
      设计规范
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)] max-w-xl mb-16">
      wangrui2025.github.io 的设计决策与实现备忘
    </p>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-text-secondary)]">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-[var(--color-text-secondary)] to-transparent animate-bounce"></div>
    </div>
  </section>

  <!-- ==================== TOC ==================== -->
  <nav class="sticky top-0 z-50 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-primary)]/80 dark:bg-[var(--color-bg-dark)]/80 backdrop-blur">
    <div class="max-w-4xl mx-auto px-6">
      <ul class="flex gap-6 overflow-x-auto py-4 text-sm">
        <li><a href="#philosophy" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Philosophy</a></li>
        <li><a href="#tokens" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Tokens</a></li>
        <li><a href="#pages" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Pages</a></li>
        <li><a href="#components" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Components</a></li>
        <li><a href="#timeline" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Timeline</a></li>
        <li><a href="#notes" class="text-[var(--color-text-secondary)] hover:text-[var(--color-link-primary)] transition-colors whitespace-nowrap">Notes</a></li>
      </ul>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-6">

    <!-- ==================== PHILOSOPHY ==================== -->
    <section id="philosophy" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">Philosophy</p>
      <h2 class="text-3xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16">设计原则</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
          <div class="text-4xl mb-4">🎓</div>
          <h3 class="text-lg font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">学术性与个人风格的平衡</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            学术主页需要专业、克制，但又要有个性。emoji 图标在学术场合不够严谨，改用 SVG icon。
          </p>
          <code class="text-xs text-[var(--color-link-primary)] break-all">6b65e397</code>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">replace emojis with flat SVG icons</p>
        </div>

        <!-- Card 2 -->
        <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="text-lg font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">性能优先，无 FOUC</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            Tailwind v4 + Vite 将 utility CSS 输出到外部文件。Critical CSS 内联到 HTML head，防止样式闪烁。
          </p>
          <code class="text-xs text-[var(--color-link-primary)] break-all">bd934e8ccf2f</code>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">move theme script before CSS to prevent FOUC</p>
        </div>

        <!-- Card 3 -->
        <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
          <div class="text-4xl mb-4">📊</div>
          <h3 class="text-lg font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">内容即接口</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            学术统计不是静态数字，通过 API 实时拉取。引用数、h-index 自动更新，不手动维护。
          </p>
          <code class="text-xs text-[var(--color-link-primary)] break-all">80a710ed1ccc</code>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">migrate from Google Scholar to OpenAlex API</p>
        </div>
      </div>
    </section>

    <!-- ==================== TOKENS ==================== -->
    <section id="tokens" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">Design Tokens</p>
      <h2 class="text-3xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16">设计令牌</h2>

      <!-- Colors -->
      <div class="mb-16">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-6">颜色</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <!-- Light theme -->
          <div>
            <p class="text-xs text-[var(--color-text-secondary)] mb-2 uppercase tracking-widest">Light</p>
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#f5f4ed]"></div>
                <div class="text-xs">
                  <p class="font-mono">bg-primary</p>
                  <p class="text-[var(--color-text-secondary)]">#f5f4ed</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#141413]"></div>
                <div class="text-xs">
                  <p class="font-mono">heading</p>
                  <p class="text-[var(--color-text-secondary)]">#141413</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#c96442]"></div>
                <div class="text-xs">
                  <p class="font-mono">link</p>
                  <p class="text-[var(--color-text-secondary)]">#c96442</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#f0eee6]"></div>
                <div class="text-xs">
                  <p class="font-mono">border</p>
                  <p class="text-[var(--color-text-secondary)]">#f0eee6</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#5e5d59]"></div>
                <div class="text-xs">
                  <p class="font-mono">text-secondary</p>
                  <p class="text-[var(--color-text-secondary)]">#5e5d59</p>
                </div>
              </div>
            </div>
          </div>
          <!-- Dark theme -->
          <div>
            <p class="text-xs text-[var(--color-text-secondary)] mb-2 uppercase tracking-widest">Dark</p>
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-dark)] bg-[#141413]"></div>
                <div class="text-xs">
                  <p class="font-mono text-[var(--color-text-dark)]">bg-dark</p>
                  <p class="text-[var(--color-text-secondary-dark)]">#141413</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-dark)] bg-[#e8e8e8]"></div>
                <div class="text-xs">
                  <p class="font-mono text-[var(--color-text-dark)]">heading-dark</p>
                  <p class="text-[var(--color-text-secondary-dark)]">#e8e8e8</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-dark)] bg-[#d97757]"></div>
                <div class="text-xs">
                  <p class="font-mono text-[var(--color-text-dark)]">link-dark</p>
                  <p class="text-[var(--color-text-secondary-dark)]">#d97757</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-dark)] bg-[#30302e]"></div>
                <div class="text-xs">
                  <p class="font-mono text-[var(--color-text-dark)]">border-dark</p>
                  <p class="text-[var(--color-text-secondary-dark)]">#30302e</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-dark)] bg-[#b0aea5]"></div>
                <div class="text-xs">
                  <p class="font-mono text-[var(--color-text-dark)]">text-sec-dark</p>
                  <p class="text-[var(--color-text-secondary-dark)]">#b0aea5</p>
                </div>
              </div>
            </div>
          </div>
          <!-- Brand colors -->
          <div>
            <p class="text-xs text-[var(--color-text-secondary)] mb-2 uppercase tracking-widest">Brand</p>
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#c96442]"></div>
                <div class="text-xs">
                  <p class="font-mono">paper-accent</p>
                  <p class="text-[var(--color-text-secondary)]">#c96442</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#4A90E2]"></div>
                <div class="text-xs">
                  <p class="font-mono">scholar</p>
                  <p class="text-[var(--color-text-secondary)]">#4A90E2</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#A6B73F]"></div>
                <div class="text-xs">
                  <p class="font-mono">orcid</p>
                  <p class="text-[var(--color-text-secondary)]">#A6B73F</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#2771B1]"></div>
                <div class="text-xs">
                  <p class="font-mono">openreview</p>
                  <p class="text-[var(--color-text-secondary)]">#2771B1</p>
                </div>
              </div>
            </div>
          </div>
          <!-- Tag colors -->
          <div>
            <p class="text-xs text-[var(--color-text-secondary)] mb-2 uppercase tracking-widest">Tags</p>
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#e8dcc8] text-[#5e4a3a] flex items-center justify-center text-xs font-bold">研</div>
                <div class="text-xs">
                  <p class="font-mono">field-bg</p>
                  <p class="text-[var(--color-text-secondary)]">研究领域</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded border border-[var(--color-border-primary)] bg-[#e8e6dc] text-[#4d4c48] flex items-center justify-center text-xs font-bold">技</div>
                <div class="text-xs">
                  <p class="font-mono">tech-bg</p>
                  <p class="text-[var(--color-text-secondary)]">技术栈</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Typography -->
      <div class="mb-16">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-6">字体</h3>
        <div class="space-y-6">
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-6">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-3">Serif — 标题 & 学术内容</p>
            <p class="font-serif text-2xl text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-2">Source Serif 4 / 思源宋体</p>
            <p class="font-serif text-lg text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] italic">Deep Learning for Computer Vision</p>
            <p class="font-serif text-sm text-[var(--color-text-secondary)] mt-2">The quick brown fox jumps over the lazy dog. 学术主页需要专业、克制，但又要有个性。</p>
          </div>
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-6">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-3">Sans — 正文 & UI</p>
            <p class="font-sans text-2xl font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-2">Inter / Inter Variable</p>
            <p class="font-sans text-sm text-[var(--color-text-secondary)]">The quick brown fox jumps over the lazy dog. 学术主页需要专业、克制，但又要有个性。计算机视觉、深度学习、人工智能。</p>
          </div>
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-6">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-3">Mono — 代码 & SHA</p>
            <p class="font-mono text-sm text-[var(--color-link-primary)]">bd934e8ccf2f · 80a710ed1ccc · 3abb297646e7</p>
            <p class="font-mono text-xs text-[var(--color-text-secondary)] mt-1">Global — &lt;Fira Code&gt;, Consolas</p>
          </div>
        </div>
      </div>

      <!-- Spacing -->
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-6">间距</h3>
        <div class="space-y-3">
          {[2, 4, 6, 8, 12, 16, 24, 32, 48].map(v => (
            <div class="flex items-center gap-4">
              <span class="text-xs font-mono text-[var(--color-text-secondary)] w-12">{v}</span>
              <div class="h-2 rounded bg-[var(--color-link-primary)]" style={`width: ${v * 4}px`}></div>
              <span class="text-xs text-[var(--color-text-secondary)]">{v * 4}px</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ==================== PAGES ==================== -->
    <section id="pages" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">Page System</p>
      <h2 class="text-3xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16">页面结构</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Home -->
        <div>
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-4 mb-4 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
            <!-- Fake homepage wireframe -->
            <div class="space-y-2">
              <div class="h-3 w-24 rounded bg-[var(--color-text-secondary)] opacity-30"></div>
              <div class="h-8 w-48 rounded bg-[var(--color-heading-primary)] dark:bg-[var(--color-heading-dark)] opacity-20"></div>
              <div class="h-2 w-32 rounded bg-[var(--color-text-secondary)] opacity-20"></div>
              <div class="mt-4 space-y-1">
                <div class="h-1.5 w-full rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
                <div class="h-1.5 w-4/5 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
                <div class="h-1.5 w-3/5 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
              </div>
              <div class="mt-3 flex gap-2">
                <div class="h-6 w-20 rounded bg-[var(--color-paper-accent)] opacity-30"></div>
                <div class="h-6 w-20 rounded bg-[var(--color-paper-accent)] opacity-20"></div>
              </div>
            </div>
          </div>
          <h3 class="font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-1">首页 <code class="text-xs text-[var(--color-link-primary)]">/</code></h3>
          <p class="text-sm text-[var(--color-text-secondary)]">研究方向、论文列表、荣誉奖励、About。ScholarBadge 显示引用数 / h-index。</p>
        </div>

        <!-- CV -->
        <div>
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-4 mb-4 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
            <div class="space-y-2">
              <div class="h-3 w-20 rounded bg-[var(--color-text-secondary)] opacity-30"></div>
              <div class="h-6 w-40 rounded bg-[var(--color-heading-primary)] dark:bg-[var(--color-heading-dark)] opacity-20"></div>
              <div class="mt-2 space-y-1">
                <div class="h-1.5 w-full rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
                <div class="h-1.5 w-full rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
                <div class="h-1.5 w-4/5 rounded bg-[var(--color-paper-accent)] opacity-30"></div>
                <div class="h-1.5 w-full rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
                <div class="h-1.5 w-3/4 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
              </div>
              <div class="mt-3 h-4 w-24 rounded bg-[var(--color-paper-accent)] opacity-20"></div>
            </div>
          </div>
          <h3 class="font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-1">简历 <code class="text-xs text-[var(--color-link-primary)]">/cv</code></h3>
          <p class="text-sm text-[var(--color-text-secondary)]">纯 HTML 渲染，支持 PDF 导出（html2pdf.js）。固定 A4 视口，移动端可缩放。</p>
        </div>

        <!-- Slides -->
        <div>
          <div class="border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-lg p-4 mb-4 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)]">
            <div class="space-y-2">
              <div class="h-6 w-full rounded bg-[var(--color-heading-primary)] dark:bg-[var(--color-heading-dark)] opacity-10"></div>
              <div class="h-px w-full bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-50"></div>
              <div class="mt-3 space-y-1">
                <div class="h-1.5 w-1/2 rounded bg-[var(--color-text-secondary)] opacity-30"></div>
                <div class="h-1 w-3/4 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-30"></div>
                <div class="h-1 w-2/3 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-30"></div>
              </div>
              <div class="mt-4 grid grid-cols-3 gap-1">
                {[1,2,3].map(() => (
                  <div class="h-8 rounded bg-[var(--color-border-primary)] dark:bg-[var(--color-border-dark)] opacity-30"></div>
                ))}
              </div>
            </div>
          </div>
          <h3 class="font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-1">论文海报 <code class="text-xs text-[var(--color-link-primary)]">/slides</code></h3>
          <p class="text-sm text-[var(--color-text-secondary)]">GDKVM (ICCV 2025)、OSA (arXiv 2026)。IEEE/CVPR 学术风格，Times New Roman。</p>
        </div>
      </div>
    </section>

    <!-- ==================== COMPONENTS ==================== -->
    <section id="components" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">Components</p>
      <h2 class="text-3xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16">组件规范</h2>

      <!-- Favicon -->
      <div class="mb-16">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] flex items-center justify-center">
            <Favicon />
          </div>
          <div>
            <h3 class="font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-1">Favicon 系统</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">皮卡丘图标 + sprites-gallery CDN + localStorage 持久化</p>
          </div>
        </div>

