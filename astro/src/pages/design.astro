---
import BaseLayout from '../layouts/BaseLayout.astro';
import Favicon from '../components/Favicon.astro';

const title = 'Design System — Rui Wang';
const description = 'wangrui2025.github.io 的设计决策与实现备忘';
---

<BaseLayout title={title} description={description} lang="en" fixedFavicon>

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center overflow-hidden">
    <!-- Animated gradient mesh background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-[var(--color-bg-primary)] dark:bg-[var(--color-bg-dark)]"></div>
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full opacity-30 bg-[#c96442] blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full opacity-20 bg-[#4A90E2] blur-[100px] animate-pulse" style="animation-duration: 12s; animation-delay: -4s;"></div>
      <div class="absolute top-1/2 right-1/3 w-[300px] h-[300px] rounded-full opacity-15 bg-[#c96442] blur-[80px] animate-pulse" style="animation-duration: 10s; animation-delay: -2s;"></div>
      <!-- Diagonal accent line -->
      <div class="absolute top-0 right-0 w-px h-full bg-gradient-to-b from-transparent via-[var(--color-paper-accent)] to-transparent opacity-20"></div>
    </div>

    <div class="relative z-10 px-6 py-32">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-paper-accent)] mb-8 font-medium">
        Design System
      </p>
      <h1 class="text-6xl md:text-8xl font-bold font-serif text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-8 leading-[0.9] tracking-tight">
        创作手记
      </h1>
      <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)] max-w-2xl mx-auto leading-relaxed mb-12">
        揭秘"我当时为什么这样想" — 我的设计决策背后的思考
      </p>

      <!-- Memoir intro -->
      <div class="max-w-xl mx-auto text-left">
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-6 text-left">
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
            <strong class="text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)]">首页</strong>是展示给所有人的干净结果，不需要解释。
            而<strong class="text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)]">这里</strong>是写给想知道"为什么"的人 — 如果你好奇我怎么选字体、为什么用这个颜色、为什么技术选这个方案，欢迎继续往下看。
          </p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator with animated line -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
      <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-secondary)]">Scroll to explore</span>
      <div class="w-px h-16 bg-gradient-to-b from-[var(--color-paper-accent)] to-transparent relative overflow-hidden rounded-full">
        <div class="absolute top-0 left-0 w-full h-4 bg-white/50 animate-bounce" style="animation-duration: 2s;"></div>
      </div>
    </div>
  </section>

  <!-- ==================== TOC ==================== -->
  <nav id="toc" class="sticky top-0 z-50 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-primary)]/90 dark:bg-[var(--color-bg-dark)]/90 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-6">
      <ul class="flex gap-1 overflow-x-auto py-4 text-sm">
        <li>
          <a href="#philosophy" data-section="philosophy" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            理念
          </a>
        </li>
        <li>
          <a href="#typography" data-section="typography" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            字体
          </a>
        </li>
        <li>
          <a href="#color" data-section="color" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            颜色
          </a>
        </li>
        <li>
          <a href="#spacing" data-section="spacing" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            间距
          </a>
        </li>
        <li>
          <a href="#dark-mode" data-section="dark-mode" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            暗黑
          </a>
        </li>
        <li>
          <a href="#tech-stack" data-section="tech-stack" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            技术
          </a>
        </li>
        <li>
          <a href="#performance" data-section="performance" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            性能
          </a>
        </li>
        <li>
          <a href="#favicon" data-section="favicon" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            图标
          </a>
        </li>
        <li>
          <a href="#timeline" data-section="timeline" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            演进
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6">

    <!-- ==================== PHILOSOPHY ==================== -->
    <section id="philosophy" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Philosophy</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        创作理念
      </h2>

      <!-- Intro -->
      <div class="max-w-3xl mb-16">
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed font-serif">
            我做这个网站的时候在想：<strong class="text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)]">首页</strong>是给所有人看的，要干净、要快、要让人舒服。
            但如果有面试官、同行、或者对设计感兴趣的人想知道<strong class="text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)]">为什么</strong>这样设计，这里就是答案。
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1: SVG Icons -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">我为什么不用 emoji？</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              学术场合需要专业感。emoji 在简历、论文里显得不够严谨。但 flat SVG icon 不一样 — 它干净、现代、而且可以精确控制颜色和大小。
            </p>
            <p class="text-xs text-[var(--color-text-secondary)] italic mb-4">
              我参考了 Stripe 和 Linear 的设计系统，它们也是用自定义 SVG icon。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">6b65e397</code>
              <span class="text-xs text-[var(--color-text-secondary)]">replace emojis with flat SVG</span>
            </div>
          </div>
        </div>

        <!-- Card 2: No FOUC -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">我遇到过 FOUC 问题</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              Tailwind v4 把 CSS 拆到外部文件，字体加载时会出现闪烁。解决方案是把关键 CSS 内联到 HTML head，这样页面打开的第一瞬间就是正确的样式。
            </p>
            <p class="text-xs text-[var(--color-text-secondary)] italic mb-4">
              这不是显而易见的解决方案 — 我花了很长时间才理解问题的根因。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">bd934e8ccf2f</code>
              <span class="text-xs text-[var(--color-text-secondary)]">move theme script before CSS</span>
            </div>
          </div>
        </div>

        <!-- Card 3: Live Data -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">我不想手动更新引用数</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              学术主页最麻烦的就是每年更新引用数。我用 API 实时拉取 Google Scholar / OpenAlex 数据，永远不需要手动改。
            </p>
            <p class="text-xs text-[var(--color-text-secondary)] italic mb-4">
              这是懒人解决方案，但懒人解决方案往往也是最好的方案。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">80a710ed1ccc</code>
              <span class="text-xs text-[var(--color-text-secondary)]">migrate to OpenAlex API</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== TYPOGRAPHY (NEW) ==================== -->
    <section id="typography" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Typography</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        字体系统
      </h2>

      <div class="space-y-12">
        <!-- Source Serif -->
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-16 h-16 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center flex-shrink-0">
              <span class="font-serif text-2xl text-[var(--color-paper-accent)]">Aa</span>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">Source Serif — 标题字体</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                我选择 Source Serif 做标题，是因为它有<strong>学术感但不死板</strong>。相比 Times New Roman，Source Serif 的曲线更柔和，适合展示论文标题。
              </p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                它和 Inter 形成良好对比 — 一个有人文的温度，一个干净现代。
              </p>
            </div>
          </div>
        </div>

        <!-- Inter -->
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-16 h-16 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center flex-shrink-0">
              <span class="font-sans text-2xl text-[var(--color-paper-accent)]">Aa</span>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-sans font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">Inter — 正文字体</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                Inter 是目前最流行的工作台字体。它在屏幕上的可读性极佳，而且有大量的 weight 可选（从 Thin 到 Black）。
              </p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                我用 Inter 做正文，配合 Source Serif 做标题，形成「古典 + 现代」的对比。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== COLOR (NEW) ==================== -->
    <section id="color" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Color</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        颜色系统
      </h2>

      <div class="space-y-12">
        <!-- Accent Color -->
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-16 h-16 rounded-xl bg-[#c96442] flex items-center justify-center flex-shrink-0">
              <span class="text-white font-mono text-sm">#c96442</span>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">#c96442 — 我为什么选这个橙褐色？</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                它足够醒目来标记重点，但<strong>不像红色那么侵略性</strong>。我在学术场合试过，面试官会注意到但不会觉得刺眼。
              </p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                如果你仔细看，Google Scholar 的链接也是类似的暖色调。我没有刻意模仿，但最后的结果是收敛的。
              </p>
            </div>
          </div>
        </div>

        <!-- Background -->
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-16 h-16 rounded-xl bg-[#f5f4ed] border border-[var(--color-border-primary)] flex items-center justify-center flex-shrink-0">
              <span class="text-[var(--color-text-secondary)] font-mono text-xs">#f5f4ed</span>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-3">#f5f4ed — 米白背景</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                不同于纯白，这个颜色更温和。配合 Source Serif 字体有书卷气，而且对眼睛更友好。
              </p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                暗黑模式下我直接用接近黑的黑 (#141413)，而不是纯黑，这样对比度更舒适。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SPACING (NEW) ==================== -->
    <section id="spacing" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Spacing</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        间距与层次
      </h2>

      <div class="space-y-8">
        <div class="bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8">
          <h3 class="text-lg font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">标题用大字号</h3>
