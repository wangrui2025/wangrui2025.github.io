---
import BaseLayout from '../layouts/BaseLayout.astro';
import Favicon from '../components/Favicon.astro';

const title = 'Design System — Rui Wang';
const description = 'wangrui2025.github.io 的设计决策与实现备忘';
---

<BaseLayout title={title} description={description} lang="en" fixedFavicon>

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center overflow-hidden">
    <!-- Animated gradient mesh background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-[var(--color-bg-primary)] dark:bg-[var(--color-bg-dark)]"></div>
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full opacity-30 bg-[#c96442] blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full opacity-20 bg-[#4A90E2] blur-[100px] animate-pulse" style="animation-duration: 12s; animation-delay: -4s;"></div>
      <div class="absolute top-1/2 right-1/3 w-[300px] h-[300px] rounded-full opacity-15 bg-[#c96442] blur-[80px] animate-pulse" style="animation-duration: 10s; animation-delay: -2s;"></div>
      <!-- Diagonal accent line -->
      <div class="absolute top-0 right-0 w-px h-full bg-gradient-to-b from-transparent via-[var(--color-paper-accent)] to-transparent opacity-20"></div>
    </div>

    <!-- Overlapping badge -->
    <div class="absolute top-8 right-8 md:top-16 md:right-16 rotate-12">
      <span class="inline-block px-4 py-2 text-xs font-mono uppercase tracking-widest bg-[var(--color-paper-accent)] text-white rounded-full shadow-lg">
        v1.0 · 854 commits
      </span>
    </div>

    <div class="relative z-10 px-6 py-32">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-paper-accent)] mb-8 font-medium">
        Design System
      </p>
      <h1 class="text-6xl md:text-8xl font-bold font-serif text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-8 leading-[0.9] tracking-tight">
        设计规范
      </h1>
      <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)] max-w-2xl mx-auto leading-relaxed">
        wangrui2025.github.io 的设计决策与实现备忘
      </p>
    </div>

    <!-- Scroll indicator with animated line -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
      <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-secondary)]">Scroll to explore</span>
      <div class="w-px h-16 bg-gradient-to-b from-[var(--color-paper-accent)] to-transparent relative overflow-hidden rounded-full">
        <div class="absolute top-0 left-0 w-full h-4 bg-white/50 animate-bounce" style="animation-duration: 2s;"></div>
      </div>
    </div>
  </section>

  <!-- ==================== TOC ==================== -->
  <nav id="toc" class="sticky top-0 z-50 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-primary)]/90 dark:bg-[var(--color-bg-dark)]/90 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-6">
      <ul class="flex gap-1 overflow-x-auto py-4 text-sm">
        <li>
          <a href="#philosophy" data-section="philosophy" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Philosophy
          </a>
        </li>
        <li>
          <a href="#tokens" data-section="tokens" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Tokens
          </a>
        </li>
        <li>
          <a href="#pages" data-section="pages" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Pages
          </a>
        </li>
        <li>
          <a href="#components" data-section="components" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Components
          </a>
        </li>
        <li>
          <a href="#timeline" data-section="timeline" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Timeline
          </a>
        </li>
        <li>
          <a href="#notes" data-section="notes" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Notes
          </a>
        </li>
        <li>
          <a href="#maintenance" data-section="maintenance" class="toc-link px-4 py-2 rounded-full text-[var(--color-text-secondary)] hover:text-[var(--color-paper-accent)] hover:bg-[var(--color-paper-accent)]/5 transition-all duration-300 whitespace-nowrap font-medium">
            Maintenance
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-6">

    <!-- ==================== PHILOSOPHY ==================== -->
    <section id="philosophy" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Philosophy</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        设计原则
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">学术性与个人风格的平衡</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              学术主页需要专业、克制，但又要有个性。emoji 图标在学术场合不够严谨，改用 SVG icon。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">6b65e397</code>
              <span class="text-xs text-[var(--color-text-secondary)]">replace emojis with flat SVG</span>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">性能优先，无 FOUC</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              Tailwind v4 + Vite 将 utility CSS 输出到外部文件。Critical CSS 内联到 HTML head，防止样式闪烁。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">bd934e8ccf2f</code>
              <span class="text-xs text-[var(--color-text-secondary)]">move theme script before CSS</span>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="group relative border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] rounded-2xl p-8 bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 hover:border-[var(--color-paper-accent)]/30">
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-[var(--color-paper-accent)]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl bg-[var(--color-paper-accent)]/10 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[var(--color-paper-accent)]/20 transition-all duration-300">
              <svg class="w-7 h-7 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-serif font-semibold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-4">内容即接口</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
              学术统计不是静态数字，通过 API 实时拉取。引用数、h-index 自动更新，不手动维护。
            </p>
            <div class="flex items-center gap-2 pt-4 border-t border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
              <code class="text-xs text-[var(--color-paper-accent)] font-mono bg-[var(--color-paper-accent)]/10 px-2 py-1 rounded">80a710ed1ccc</code>
              <span class="text-xs text-[var(--color-text-secondary)]">migrate to OpenAlex API</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== TOKENS ==================== -->
    <section id="tokens" class="py-32 border-b border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)]">
      <div class="flex items-baseline gap-6 mb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-paper-accent)] font-semibold">Design Tokens</p>
        <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-paper-accent)]/50 to-transparent"></span>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-[var(--color-heading-primary)] dark:text-[var(--color-heading-dark)] mb-16 leading-tight">
        设计令牌
      </h2>

      <!-- Colors -->
      <div class="mb-20">
        <h3 class="text-lg font-semibold text-[var(--color-text-primary)] dark:text-[var(--color-text-dark)] mb-8 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-[var(--color-paper-accent)]/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-[var(--color-paper-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
            </svg>
          </span>
          颜色
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <!-- Light theme -->
          <div class="space-y-4">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] font-semibold">Light</p>
            <div class="flex flex-col gap-3">
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#f5f4ed] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">bg-primary</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#f5f4ed</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#141413] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">heading</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#141413</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#c96442] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">link</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#c96442</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#f0eee6] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">border</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#f0eee6</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#5e5d59] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">text-secondary</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#5e5d59</p>
                </div>
              </div>
            </div>
          </div>
          <!-- Dark theme -->
          <div class="space-y-4">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] font-semibold">Dark</p>
            <div class="flex flex-col gap-3">
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-dark)] bg-[#141413] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-dark)]">bg-dark</p>
                  <p class="text-xs text-[var(--color-text-secondary-dark)] font-mono">#141413</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-dark)] bg-[#e8e8e8] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-dark)]">heading-dark</p>
                  <p class="text-xs text-[var(--color-text-secondary-dark)] font-mono">#e8e8e8</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-dark)] bg-[#d97757] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-dark)]">link-dark</p>
                  <p class="text-xs text-[var(--color-text-secondary-dark)] font-mono">#d97757</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-dark)] bg-[#30302e] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-dark)]">border-dark</p>
                  <p class="text-xs text-[var(--color-text-secondary-dark)] font-mono">#30302e</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-dark)] bg-[#b0aea5] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-dark)]">text-sec-dark</p>
                  <p class="text-xs text-[var(--color-text-secondary-dark)] font-mono">#b0aea5</p>
                </div>
              </div>
            </div>
          </div>
          <!-- Brand colors -->
          <div class="space-y-4">
            <p class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] font-semibold">Brand</p>
            <div class="flex flex-col gap-3">
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#c96442] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">paper-accent</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#c96442</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 rounded-lg border border-[var(--color-border-primary)] bg-[#4A90E2] shadow-sm group-hover:scale-105 transition-transform"></div>
                <div class="flex-1 min-w-0">
                  <p class="font-mono text-sm text-[var(--color-text-primary)]">scholar</p>
                  <p class="text-xs text-[var(--color-text-secondary)] font-mono">#4A90E2</p>
                </div>
              </div>
              <div class="group flex items-center gap-4 p-3 rounded-xl bg-[var(--color-paper-bg)] dark:bg-[var(--color-paper-bg-dark)] border border-[var(--color-border-primary)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-paper-accent)]/50 transition-colors cursor-pointer">
