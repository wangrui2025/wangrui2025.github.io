---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';

const title = 'Page Not Found - 404';
const description = 'Sorry, the page you are looking for does not exist.';

const homeEn = getRelativeLocaleUrl('en', '');
const homeZh = getRelativeLocaleUrl('zh', '');
---

<BaseLayout title={title} description={description} lang="en">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center px-4">
    <h1 class="font-sans font-medium text-[80px] leading-none text-paper-accent dark:text-paper-accent-dark mb-4">
      <span class="en-404">404</span>
      <span class="zh-404 hidden">404</span>
    </h1>
    <h2 class="font-sans font-medium text-[28px] leading-tight text-text-primary dark:text-text-dark mb-4">
      <span class="en-404">Page Not Found</span>
      <span class="zh-404 hidden">页面未找到</span>
    </h2>
    <p class="text-base text-text-secondary dark:text-text-secondary-dark mb-8 max-w-md">
      <span class="en-404">Sorry, the page you are looking for does not exist or has been moved.</span>
      <span class="zh-404 hidden">抱歉，您访问的页面不存在或已被移动。</span>
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href={homeEn}
        class="en-404 inline-flex items-center px-5 py-2.5 rounded-lg bg-paper-accent dark:bg-paper-accent-dark text-paper-bg dark:text-paper-bg-dark font-medium hover:opacity-90 transition-opacity"
      >
        Back to Home
      </a>
      <a
        href={homeZh}
        class="zh-404 hidden inline-flex items-center px-5 py-2.5 rounded-lg bg-paper-accent dark:bg-paper-accent-dark text-paper-bg dark:text-paper-bg-dark font-medium hover:opacity-90 transition-opacity"
      >
        返回首页
      </a>
      <a
        href={homeZh}
        class="en-404 inline-flex items-center px-5 py-2.5 rounded-lg border border-border-primary dark:border-border-dark text-text-primary dark:text-text-dark hover:bg-bg-primary/80 dark:hover:bg-bg-dark/80 transition-colors"
      >
        中文页面
      </a>
      <a
        href={homeEn}
        class="zh-404 hidden inline-flex items-center px-5 py-2.5 rounded-lg border border-border-primary dark:border-border-dark text-text-primary dark:text-text-dark hover:bg-bg-primary/80 dark:hover:bg-bg-dark/80 transition-colors"
      >
        English Version
      </a>
    </div>
  </div>

  <script src="/scripts/404-i18n.js" is:inline></script>
</BaseLayout>
