---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import AuthorProfile from '../../components/AuthorProfile.astro';
import PaperCard from '../../components/PaperCard.astro';
import Education from '../../components/Education.astro';
import ScholarBadge from '../../components/ScholarBadge.astro';
import { getEntry } from 'astro:content';
import { honors } from '../../data';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
  ];
}

const lang = Astro.params.lang as 'en' | 'zh';

// Get homepage content from Content Collection
const homepage = await getEntry('homepage', lang);
const h = homepage.data;

// Get scholar stats for citation badge
const scholarStats = await getEntry('scholar', 'stats');
const citedBy = scholarStats.data.citedby;
---

<BaseLayout
  title={h.title}
  description={h.description}
  lang={lang}
>
  <Sidebar slot="sidebar">
    <AuthorProfile lang={lang} />
  </Sidebar>

  <!-- About Me Section -->
  <section id="about-me" class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{lang === 'zh' ? '关于我' : 'About Me'}</h1>
    <p class="status-badge mb-4">{h.status_badge}</p>
    <p class="mb-4" set:html={h.background.intro} />
    <p class="mb-4" set:html={h.background.research} />

    <div class="mb-4">
      <h2 class="text-xl font-semibold mb-2">{h.background.heading}</h2>
      <ul class="about-list">
        {h.background.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="mb-4">
      <h2 class="text-xl font-semibold mb-2">
        {h.target_areas.heading} {h.target_areas.subheading}
      </h2>
      <ul class="about-list">
        {h.target_areas.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

  </section>

  <!-- News Section -->
  <section id="status" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.news_heading}
    </h2>
    <ul class="news-list">
      {h.news_items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <!-- Publications Section -->
  <section id="publications" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_publications}
    </h2>
    <PaperCard paperKey="osa" lang={lang} />
    <PaperCard paperKey="gdkvm" lang={lang} />
  </section>

  <!-- Education Section -->
  <section id="educations" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_education}
    </h2>
    <Education type="master" lang={lang} />
    <Education type="bachelor" lang={lang} />
  </section>

  <!-- Honors Section -->
  <section id="honors" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_honors}
    </h2>

    <h3 class="text-lg font-semibold mb-2">{h.honors_graduate_header}</h3>
    <ul class="honors-list mb-4">
      {honors.graduate[lang].map((item) => (
        <li><span class="period">{item.period}</span> {item.text}</li>
      ))}
    </ul>

    <h3 class="text-lg font-semibold mb-2">{h.honors_undergraduate_header}</h3>
    <ul class="honors-list">
      {honors.undergraduate[lang].map((item) => (
        <li><span class="period">{item.period}</span> {item.text}</li>
      ))}
    </ul>
  </section>

  <!-- Project Section -->
  <section id="project" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_project}
    </h2>
    <ul class="project-list">
      <li>
        <a href={h.project_url} class="font-semibold hover:underline" target="_blank">
          {h.project_title}
        </a>
        <p class="text-gray-600 dark:text-gray-300 mt-1">{h.project_description}</p>
      </li>
    </ul>
  </section>

  <!-- Skills & Interests Section -->
  <section id="skills" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_skills}
    </h2>
    <ul class="skills-list">
      {h.skills_items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <!-- Google Scholar Badge -->
  <ScholarBadge citations={citedBy} />
</BaseLayout>
