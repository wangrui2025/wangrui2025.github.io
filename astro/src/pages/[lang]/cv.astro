---
import CVLayout from '../../layouts/CVLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { cvData } from '../../data/cv';
import CvPaperItem from '../../components/CvPaperItem.astro';
import CvHonorItem from '../../components/CvHonorItem.astro';
import CvEducationItem from '../../components/CvEducationItem.astro';
import { Icon } from 'astro-icon/components';
import '../../styles/cv.css';

// Only generate Chinese route - English is at /cv.astro
export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
  ];
}

const lang = Astro.params.lang as 'en' | 'zh';
const cv = cvData[lang];
const isZh = lang === 'zh';

// Translations
const t = {
  en: {
    title: 'CV - Rui Wang',
    description: 'Curriculum Vitae of Rui Wang',
    education: 'Education',
    publications: 'Publications',
    researchDirections: 'Research Directions',
    honors: 'Honors & Awards',
    projects: 'Projects',
    skills: 'Skills',
    hobbies: 'Hobbies',
  },
  zh: {
    title: '简历 - 王锐',
    description: '王锐个人简历',
    education: '教育经历',
    publications: '发表论文',
    researchDirections: '研究方向',
    honors: '荣誉奖项',
    projects: '项目经历',
    skills: '个人技能',
    hobbies: '兴趣特长',
  },
};

const labels = t[lang];

// Fetch from content collections
const papersCollection = await getCollection('papers', (p) => p.data.show_on_cv);
const honors = await getEntry('honors', 'honors')!;
const education = await getEntry('education', 'education')!;

// Sort papers by date (newest first) - use spread to avoid mutation
const sortedPapers = [...papersCollection].sort((a, b) => b.data.date.localeCompare(a.data.date));

// Get first project safely
const firstProject = cv.projects.length > 0 ? cv.projects[0] : null;

// Flatten honors with type标签
const graduateHonors = honors.data.graduate
  .filter((h) => h.show_on_cv)
  .map((h) => ({ ...h, type: 'graduate' as const }));
const undergraduateHonors = honors.data.undergraduate
  .filter((h) => h.show_on_cv)
  .map((h) => ({ ...h, type: 'undergraduate' as const }));
---

<CVLayout
  title={labels.title}
  description={labels.description}
  lang={lang}
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">{cv.personal.name}</h1>
      <div class="cv-contact">
        <span>{cv.personal.phone}</span>
        <span class="sep">{isZh ? '丨' : '|'}</span>
        {!isZh && <span>wangrui</span>}
        {!isZh && <span class="sep">|</span>}
        <span>{cv.personal.location}</span>
        <span class="sep">{isZh ? '丨' : '|'}</span>
        <span>{cv.personal.gender}</span>
        <span class="sep">{isZh ? '丨' : '|'}</span>
        <span>wr_szu@163.com</span>
        <span class="sep">{isZh ? '丨' : '|'}</span>
        <a href="https://wangrui2025.github.io/" target="_blank" rel="noopener">homepage</a>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:school" class="w-4 h-4 text-[#c96442]" />{labels.education}</h2>
      <CvEducationItem
        university={education.data.master.university}
        universityUrl={education.data.master.universityUrl}
        major={education.data.master.major}
        degree={education.data.master.degree}
        period={education.data.master.period}
        detail={education.data.master.detail}
        lang={lang}
      />
      <CvEducationItem
        university={education.data.bachelor.university}
        universityUrl={education.data.bachelor.universityUrl}
        major={education.data.bachelor.major}
        degree={education.data.bachelor.degree}
        period={education.data.bachelor.period}
        detail={education.data.bachelor.detail}
        examScores={education.data.bachelor.examScores}
        lang={lang}
      />
    </section>

    <!-- Publications -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:file-dots" class="w-4 h-4 text-[#c96442]" />{labels.publications}</h2>
      {sortedPapers.map((paper) => (
        <CvPaperItem paper={paper} lang="zh" titleLang="en" />
      ))}
    </section>

    <!-- Research Directions -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:target" class="w-4 h-4 text-[#c96442]" />{labels.researchDirections}</h2>
      <div class="cv-grid-2">
        {cv.researchDirections.map((dir) => (
          <div class="cv-bullet-item">
            <span class="cv-bullet-main">• {dir.main}</span>
            {dir.sub && <span class="cv-bullet-sub"> / {dir.sub}</span>}
          </div>
        ))}
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:trophy" class="w-4 h-4 text-[#c96442]" />{labels.honors}</h2>
      <div class="cv-grid">
        {graduateHonors.map((honor) => (
          <CvHonorItem
            text={honor[lang].text}
            period={honor.period}
            secondary={false}
          />
        ))}
        {undergraduateHonors.map((honor) => (
          <CvHonorItem
            text={honor[lang].text}
            period={honor.period}
            secondary={false}
          />
        ))}
        {cv.honors.map((honor) => (
          <CvHonorItem
            text={honor.text}
            period={honor.period}
            secondary={honor.secondary ?? true}
          />
        ))}
      </div>
    </section>

    <!-- Projects -->
    {firstProject && (
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:package" class="w-4 h-4 text-[#c96442]" />{labels.projects}</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">
            {firstProject.url
              ? <a href={firstProject.url} target="_blank" rel="noopener" class="project-name-link">{firstProject.name}</a>
              : firstProject.name
            }
          </span>
          <span class="cv-entry-period">{firstProject.type}</span>
        </div>
        <div class="cv-entry-detail">{firstProject.description}</div>
      </div>
    </section>
    )}

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:code" class="w-4 h-4 text-[#c96442]" />{labels.skills}</h2>
      <div class="cv-grid-2">
        {cv.skills.map((skill) => (
          <div><span class="skill-label">{skill.category}{isZh ? '：' : ':'}</span> {skill.items}</div>
        ))}
      </div>
    </section>

    <!-- Hobbies -->
    <section class="cv-section">
      <h2 class="cv-section-title flex items-center gap-1"><Icon name="tabler:heart" class="w-4 h-4 text-[#c96442]" />{labels.hobbies}</h2>
      <div class="cv-hobbies">
        {cv.hobbies.map((hobby, i) => (
          <>
            <span>{hobby}</span>
            {i < cv.hobbies.length - 1 && <span class="sep-dot">·</span>}
          </>
        ))}
      </div>
    </section>
  </section>
</CVLayout>
