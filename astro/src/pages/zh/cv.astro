---
import CVLayout from '../../layouts/CVLayout.astro';
---

<CVLayout
  title="简历 - 王锐"
  description="王锐个人简历"
  lang="zh"
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">王锐</h1>
      <div class="cv-contact">
        <span>15938550910</span>
        <span class="sep">丨</span>
        <span>wangrui</span>
        <span class="sep">丨</span>
        <span>深圳大学</span>
      </div>
      <div class="cv-meta">
        <span>2001-10</span>
        <span class="sep">丨</span>
        <span>男</span>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title">教育经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">深圳大学</span>
          <span class="cv-entry-period">2024.09 - 2027.06 (预计)</span>
        </div>
        <div class="cv-entry-sub">计算机科学与技术 硕士 · 计算机与软件学院</div>
        <div class="cv-entry-detail">导师：吴惠思教授 · 研究方向：超声心动图视频分割</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">河南大学</span>
          <span class="cv-entry-period">2020.09 - 2024.06</span>
        </div>
        <div class="cv-entry-sub">数据科学与大数据技术 本科 · 计算机与信息工程学院</div>
        <div class="cv-entry-detail">开封 | GPA: 3.45/4.00 | 排名: 15/128 (前11%) | CET-4: 548 | CET-6: 435</div>
      </div>
    </section>

    <!-- Publications -->
    <section class="cv-section">
      <h2 class="cv-section-title">发表论文</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">OSA: Orthogonal State Update with Anatomical Prior-aware Feature Enhancement for Echocardiography Video Segmentation</span>
          <span class="cv-entry-period">CVPR 2026</span>
        </div>
        <div class="cv-entry-sub">王锐, 吴惠思 等</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">GDKVM: Gated Delta Rule-based Spatio-Temporal Key-Value Memory for Echocardiography Video Segmentation</span>
          <span class="cv-entry-period">ICCV 2025</span>
        </div>
        <div class="cv-entry-sub">王锐, 吴惠思 等</div>
      </div>
    </section>

    <!-- Research Directions -->
    <section class="cv-section">
      <h2 class="cv-section-title">研究方向</h2>
      <div class="cv-grid-2">
        <div>• 高效神经网络架构设计</div>
        <div>• 非凸优化 / 几何深度学习</div>
        <div>• 计算机视觉长程依赖建模</div>
        <div>• 大规模多模态预训练</div>
        <div>• 视觉-语言模型推理效率优化</div>
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title">荣誉奖项</h2>
      <div class="cv-grid">
        <div class="cv-grid-item"><span>研究生国家奖学金</span><span class="right">2025.12</span></div>
        <div class="cv-grid-item"><span>深圳大学研究生学业奖学金一等奖</span><span class="right">2025.12</span></div>
        <div class="cv-grid-item"><span>深圳大学研究生学业奖学金特等奖</span><span class="right">2024.12</span></div>
        <div class="cv-grid-item"><span>深圳大学学术启航奖学金</span><span class="right">2026.01</span></div>
        <div class="cv-grid-item"><span>河南大学三好学生及奖学金</span><span class="right">2022.12</span></div>
        <div class="cv-grid-item"><span>CCF-CSP认证 — 170分（前28%）</span><span class="right">2022.03</span></div>
        <div class="cv-grid-item"><span>第十三届蓝桥杯C/C++程序设计组 — 省三等奖</span><span class="right">2022.05</span></div>
        <div class="cv-grid-item"><span>第十六届中国大学生计算机设计大赛 — 省三等奖</span><span class="right">2023.05</span></div>
        <div class="cv-grid-item"><span>第十六届"挑战杯"大学生课外学术科技作品竞赛 — 省三等奖</span><span class="right">2023.08</span></div>
        <div class="cv-grid-item"><span>第九届中国"互联网+"大学生创新创业大赛 — 省三等奖</span><span class="right">2023.08</span></div>
      </div>
    </section>

    <!-- Project -->
    <section class="cv-section">
      <h2 class="cv-section-title">项目经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">how2research</span>
          <span class="cv-entry-period">开源项目</span>
        </div>
        <div class="cv-entry-sub">面向研究生的开源科研指南</div>
        <div class="cv-entry-detail">涵盖 CVPR/ICCV 投稿流程、高效 LaTeX 写作技巧、科研 Prompt 工程及开发环境配置（uv, VSCode）等。由 "miyuki11" 维护。</div>
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title">个人技能</h2>
      <div class="cv-grid-2">
        <div><span class="skill-label">编程语言：</span>Python, C/C++, SQL, JavaScript</div>
        <div><span class="skill-label">深度学习：</span>PyTorch, TensorFlow, 医学影像分析</div>
        <div><span class="skill-label">开发工具：</span>Git, Linux, Docker, VS Code, PyCharm</div>
        <div><span class="skill-label">科研工具：</span>Claude Code, Harness Engineering, LaTeX</div>
      </div>
    </section>

    <!-- Hobbies -->
    <section class="cv-section">
      <h2 class="cv-section-title">兴趣特长 Hobbies</h2>
      <div class="cv-hobbies">
        <span>排球</span>
        <span class="sep-dot">·</span>
        <span>棒垒球</span>
        <span class="sep-dot">·</span>
        <span>书法</span>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  /* A4: 210mm x 297mm */
  .cv-page {
    font-family: 'Times New Roman', 'Noto Serif SC', serif;
    font-size: 10pt;
    line-height: 1.35;
    width: 210mm;
    min-height: 297mm;
    max-width: 210mm;
    margin: 0 auto;
    padding: 15mm 20mm;
    background: white;
    color: #1a1a1a;
    box-sizing: border-box;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 12pt;
    padding-bottom: 8pt;
    border-bottom: 1.5pt solid #1a1a1a;
  }

  .cv-name {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: 3pt;
    margin: 0 0 2pt 0;
  }

  .cv-name-en {
    font-size: 11pt;
    font-weight: 400;
    letter-spacing: 1pt;
    margin: 0 0 6pt 0;
    color: #555;
  }

  .cv-contact,
  .cv-meta {
    font-size: 9pt;
    color: #444;
    margin-bottom: 2pt;
  }

  .sep {
    margin: 0 6pt;
    color: #999;
  }

  .cv-section {
    margin-bottom: 9pt;
  }

  .cv-section-title {
    font-size: 10.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: 5pt;
    padding-bottom: 2pt;
    border-bottom: 0.75pt solid #1a1a1a;
  }

  .cv-entry {
    margin-bottom: 5pt;
  }

  .cv-entry:last-child {
    margin-bottom: 0;
  }

  .cv-entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 6pt;
  }

  .cv-entry-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
  }

  .cv-entry-period {
    font-size: 9pt;
    color: #666;
    flex-shrink: 0;
  }

  .cv-entry-sub {
    font-size: 9pt;
    color: #444;
    margin-top: 1pt;
  }

  .cv-entry-detail {
    font-size: 8.5pt;
    color: #666;
    margin-top: 1pt;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2pt 8pt;
  }

  .cv-grid-item {
    display: contents;
  }

  .cv-grid-item > span:first-child {
    font-size: 9pt;
  }

  .cv-grid-item .right {
    font-size: 9pt;
    color: #666;
    text-align: right;
    flex-shrink: 0;
  }

  .cv-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2pt 12pt;
    font-size: 9pt;
  }

  .skill-label {
    font-weight: 600;
  }

  .cv-hobbies {
    font-size: 9pt;
    color: #444;
  }

  .sep-dot {
    margin: 0 6pt;
    color: #999;
  }
</style>
