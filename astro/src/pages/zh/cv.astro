---
import CVLayout from '../../layouts/CVLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { cvData } from '../../data/cv';
import CvPaperItem from '../../components/CvPaperItem.astro';
import CvHonorItem from '../../components/CvHonorItem.astro';
import CvEducationItem from '../../components/CvEducationItem.astro';

const cv = cvData.zh;
const lang: 'en' | 'zh' = 'zh';

// Fetch from content collections
const papersCollection = await getCollection('papers', (p) => p.data.show_on_cv);
const honors = await getEntry('honors', 'honors');
const education = await getEntry('education', 'education');

// Sort papers by date (newest first)
const sortedPapers = papersCollection.sort((a, b) => b.data.date.localeCompare(a.data.date));

// Flatten honors with type标签
const graduateHonors = honors.data.graduate
  .filter((h) => h.show_on_cv)
  .map((h) => ({ ...h, type: 'graduate' as const }));
const undergraduateHonors = honors.data.undergraduate
  .filter((h) => h.show_on_cv)
  .map((h) => ({ ...h, type: 'undergraduate' as const }));
---

<CVLayout
  title="简历 - 王锐"
  description="王锐个人简历"
  lang={lang}
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">{cv.personal.name}</h1>
      <div class="cv-contact">
        <span>{cv.personal.phone}</span>
        <span class="sep">丨</span>
        <span>{cv.personal.location}</span>
        <span class="sep">丨</span>
        <span>{cv.personal.gender}</span>
      </div>
      <div class="cv-contact">
        <span>wr_szu@163.com</span>
        <span class="sep">丨</span>
        <a href="https://wangrui2025.github.io/" target="_blank" rel="noopener">homepage</a>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title">教育经历</h2>
      <CvEducationItem
        university={education.data.master.university}
        universityUrl={education.data.master.universityUrl}
        major={education.data.master.major}
        degree={education.data.master.degree}
        period={education.data.master.period}
        detail={education.data.master.detail}
        lang={lang}
      />
      <CvEducationItem
        university={education.data.bachelor.university}
        universityUrl={education.data.bachelor.universityUrl}
        major={education.data.bachelor.major}
        degree={education.data.bachelor.degree}
        period={education.data.bachelor.period}
        detail={education.data.bachelor.detail}
        examScores={education.data.bachelor.examScores}
        lang={lang}
      />
    </section>

    <!-- Publications -->
    <section class="cv-section">
      <h2 class="cv-section-title">发表论文</h2>
      {sortedPapers.map((paper) => (
        <CvPaperItem paper={paper} lang={lang} />
      ))}
    </section>

    <!-- Research Directions -->
    <section class="cv-section">
      <h2 class="cv-section-title">研究方向</h2>
      <div class="cv-grid-2">
        {cv.researchDirections.map((dir) => (
          <div>• {dir}</div>
        ))}
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title">荣誉奖项</h2>
      <div class="cv-grid">
        {graduateHonors.map((honor) => (
          <CvHonorItem
            text={honor.zh.text}
            period={honor.period}
            secondary={false}
          />
        ))}
        {undergraduateHonors.map((honor) => (
          <CvHonorItem
            text={honor.zh.text}
            period={honor.period}
            secondary={true}
          />
        ))}
        {cv.honors.map((honor) => (
          <CvHonorItem
            text={honor.text}
            period={honor.period}
            secondary={honor.secondary ?? true}
          />
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="cv-section">
      <h2 class="cv-section-title">项目经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">
            {cv.projects[0].url
              ? <a href={cv.projects[0].url} target="_blank" rel="noopener" class="project-name-link">{cv.projects[0].name}</a>
              : cv.projects[0].name
            }
          </span>
          <span class="cv-entry-period">{cv.projects[0].type}</span>
        </div>
        <div class="cv-entry-sub">面向研究生的开源科研指南</div>
        <div class="cv-entry-detail">{cv.projects[0].description}</div>
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title">个人技能</h2>
      <div class="cv-grid-2">
        {cv.skills.map((skill) => (
          <div><span class="skill-label">{skill.category}：</span>{skill.items}</div>
        ))}
      </div>
    </section>

    <!-- Hobbies -->
    <section class="cv-section">
      <h2 class="cv-section-title">兴趣特长</h2>
      <div class="cv-hobbies">
        {cv.hobbies.map((hobby, i) => (
          <>
            <span>{hobby}</span>
            {i < cv.hobbies.length - 1 && <span class="sep-dot">·</span>}
          </>
        ))}
      </div>
    </section>
  </section>
</CVLayout>

<style>
  /* A4: 210mm x 297mm */
  .cv-page {
    font-family: 'Times New Roman', 'Noto Serif SC', serif;
    font-size: 10pt;
    line-height: 1.35;
    width: 210mm;
    min-height: 297mm;
    max-width: 210mm;
    margin: 0 auto;
    padding: 15mm 20mm;
    background: white;
    color: #1a1a1a;
    box-sizing: border-box;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 12pt;
    padding-bottom: 8pt;
    border-bottom: 1.5pt solid #1a1a1a;
  }

  .cv-name {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: 3pt;
    margin: 0 0 2pt 0;
  }

  .cv-contact,
  .cv-meta {
    font-size: 9pt;
    color: #444;
    margin-bottom: 2pt;
  }

  .sep {
    margin: 0 6pt;
    color: #999;
  }

  .cv-section {
    margin-bottom: 9pt;
  }

  .cv-section-title {
    font-size: 10.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: 5pt;
    padding-bottom: 2pt;
    border-bottom: 0.75pt solid #1a1a1a;
  }

  .cv-entry {
    margin-bottom: 5pt;
  }

  .cv-entry:last-child {
    margin-bottom: 0;
  }

  .cv-entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 6pt;
  }

  .cv-entry-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
  }

  .cv-entry-sub {
    font-size: 9pt;
    color: #444;
    margin-top: 1pt;
  }

  .cv-entry-detail {
    font-size: 8.5pt;
    color: #666;
    margin-top: 1pt;
  }

  .cv-grid {
    display: flex;
    flex-direction: column;
    gap: 2pt;
  }

  .cv-grid-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8pt;
  }

  .cv-grid-item > span:first-child {
    font-size: 9pt;
    word-break: break-word;
    color: #bbb;
  }

  .cv-grid-item:not(.secondary) > span:first-child {
    color: #1a1a1a;
  }

  .secondary-tag {
    font-size: 7pt;
    color: #999;
    border: 0.5pt solid #ccc;
    border-radius: 2pt;
    padding: 0 2pt;
    margin-left: 3pt;
    vertical-align: middle;
  }

  .cv-grid-item .right {
    font-size: 9pt;
    color: #666;
    text-align: right;
    flex-shrink: 0;
  }

  .cv-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2pt 12pt;
    font-size: 9pt;
  }

  .skill-label {
    font-weight: 600;
  }

  .cv-hobbies {
    font-size: 9pt;
    color: #444;
  }

  /* Publications - Hanging layout (悬挂式布局) */
  .cv-pub-entry {
    position: relative;
    padding-left: 55pt;
    margin-bottom: 6pt;
  }

  .cv-pub-venue {
    position: absolute;
    left: 0;
    top: 0;
    width: 52pt;
    font-size: 8.5pt;
    color: #555;
    font-weight: 700;
    word-break: break-word;
    text-align: right;
  }

  .cv-pub-main {
    display: flex;
    flex-direction: column;
    gap: 1pt;
  }

  .cv-pub-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  .cv-pub-authors {
    font-size: 9pt;
    line-height: 1.4;
  }

  .cv-pub-links {
    display: flex;
    gap: 8pt;
    margin-top: 1pt;
  }

  /* Authors */
  .author-self {
    color: #1a1a1a;
  }

  .author-other {
    font-weight: 400;
    color: #666;
  }

  .pub-link {
    font-size: 8.5pt;
    color: #444;
    text-decoration: none;
  }

  .pub-link:hover {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .sep-dot {
    margin: 0 6pt;
    color: #999;
  }

  .project-name-link {
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 0.5pt solid #1a1a1a;
  }
</style>
