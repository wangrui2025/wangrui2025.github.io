---
import CVLayout from '../../layouts/CVLayout.astro';
import { cvData } from '../../data/cv';

const cv = cvData.zh;
const lang = 'zh';
---

<CVLayout
  title="简历 - 王锐"
  description="王锐个人简历"
  lang={lang}
>
  <section id="cv" class="cv-page">
    <!-- Header -->
    <header class="cv-header">
      <h1 class="cv-name">{cv.personal.name}</h1>
      <div class="cv-contact">
        <span>{cv.personal.phone}</span>
        <span class="sep">丨</span>
        <span>{cv.personal.location}</span>
        <span class="sep">丨</span>
        <span>{cv.personal.gender}</span>
      </div>
      <div class="cv-contact">
        <span>wr_szu@163.com</span>
        <span class="sep">丨</span>
        <a href="https://wangrui2025.github.io/" target="_blank" rel="noopener">homepage</a>
      </div>
    </header>

    <!-- Education -->
    <section class="cv-section">
      <h2 class="cv-section-title">教育经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">{cv.education.master.university}</span>
          <span class="cv-entry-period">{cv.education.master.period}</span>
        </div>
        <div class="cv-entry-sub">{cv.education.master.major}</div>
        <div class="cv-entry-detail">{cv.education.master.detail}</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">{cv.education.bachelor.university}</span>
          <span class="cv-entry-period">{cv.education.bachelor.period}</span>
        </div>
        <div class="cv-entry-sub">{cv.education.bachelor.major}</div>
        <div class="cv-entry-detail">{cv.education.bachelor.detail}</div>
        <div class="cv-entry-detail">{cv.education.bachelor.examScores}</div>
      </div>
    </section>

    <!-- Publications -->
    <section class="cv-section">
      <h2 class="cv-section-title">发表论文</h2>
      {cv.publications.map((pub) => (
        <div class="cv-pub-entry">
          <div class="cv-pub-venue">[{pub.conference}]</div>
          <div class="cv-pub-main">
            <div class="cv-pub-title">{pub.title}</div>
            <div class="cv-pub-authors">
              {pub.authors.map((author, i) => (<><span class={author.isSelf ? 'author-self' : 'author-other'}>{author.name}</span>{i < pub.authors.length - 1 && <span class="author-sep">，</span>}</>))}
            </div>
            <div class="cv-pub-links">
              {pub.arxiv && (
                <a href={pub.arxiv} target="_blank" rel="noopener" class="pub-link">
                  [arXiv]
                </a>
              )}
              {pub.projectUrl && (
                <a href={pub.projectUrl} target="_blank" rel="noopener" class="pub-link">
                  [Project]
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Research Directions -->
    <section class="cv-section">
      <h2 class="cv-section-title">研究方向</h2>
      <div class="cv-grid-2">
        {cv.researchDirections.map((dir) => (
          <div>• {dir}</div>
        ))}
      </div>
    </section>

    <!-- Honors -->
    <section class="cv-section">
      <h2 class="cv-section-title">荣誉奖项</h2>
      <div class="cv-grid">
        {cv.honors.map((honor) => (
          <div class={`cv-grid-item${honor.secondary ? ' secondary' : ''}`}>
            <span>{honor.text}{honor.secondary && <span class="secondary-tag">次级</span>}</span>
            <span class="right">{honor.period}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="cv-section">
      <h2 class="cv-section-title">项目经历</h2>
      <div class="cv-entry">
        <div class="cv-entry-row">
          <span class="cv-entry-title">
            {cv.projects[0].url
              ? <a href={cv.projects[0].url} target="_blank" rel="noopener" class="project-name-link">{cv.projects[0].name}</a>
              : cv.projects[0].name
            }
          </span>
          <span class="cv-entry-period">{cv.projects[0].type}</span>
        </div>
        <div class="cv-entry-sub">面向研究生的开源科研指南</div>
        <div class="cv-entry-detail">{cv.projects[0].description}</div>
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <h2 class="cv-section-title">个人技能</h2>
      <div class="cv-grid-2">
        {cv.skills.map((skill) => (
          <div><span class="skill-label">{skill.category}：</span>{skill.items}</div>
        ))}
      </div>
    </section>

    <!-- Hobbies -->
    <section class="cv-section">
      <h2 class="cv-section-title">兴趣特长</h2>
      <div class="cv-hobbies">
        {cv.hobbies.map((hobby, i) => (
          <>
            <span>{hobby}</span>
            {i < cv.hobbies.length - 1 && <span class="sep-dot">·</span>}
          </>
        ))}
      </div>
    </section>
  </section>
</CVLayout>

<style>
  /* A4: 210mm x 297mm */
  .cv-page {
    font-family: 'Times New Roman', 'Noto Serif SC', serif;
    font-size: 10pt;
    line-height: 1.35;
    width: 210mm;
    min-height: 297mm;
    max-width: 210mm;
    margin: 0 auto;
    padding: 15mm 20mm;
    background: white;
    color: #1a1a1a;
    box-sizing: border-box;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 12pt;
    padding-bottom: 8pt;
    border-bottom: 1.5pt solid #1a1a1a;
  }

  .cv-name {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: 3pt;
    margin: 0 0 2pt 0;
  }

  .cv-contact,
  .cv-meta {
    font-size: 9pt;
    color: #444;
    margin-bottom: 2pt;
  }

  .sep {
    margin: 0 6pt;
    color: #999;
  }

  .cv-section {
    margin-bottom: 9pt;
  }

  .cv-section-title {
    font-size: 10.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: 5pt;
    padding-bottom: 2pt;
    border-bottom: 0.75pt solid #1a1a1a;
  }

  .cv-entry {
    margin-bottom: 5pt;
  }

  .cv-entry:last-child {
    margin-bottom: 0;
  }

  .cv-entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 6pt;
  }

  .cv-entry-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
  }

  .cv-entry-sub {
    font-size: 9pt;
    color: #444;
    margin-top: 1pt;
  }

  .cv-entry-detail {
    font-size: 8.5pt;
    color: #666;
    margin-top: 1pt;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2pt 8pt;
  }

  .cv-grid-item {
    display: contents;
  }

  .cv-grid-item > span:first-child {
    font-size: 9pt;
    color: #999;
  }

  .cv-grid-item:not(.secondary) > span:first-child {
    color: #1a1a1a;
  }

  .secondary-tag {
    font-size: 7pt;
    color: #999;
    border: 0.5pt solid #ccc;
    border-radius: 2pt;
    padding: 0 2pt;
    margin-left: 3pt;
    vertical-align: middle;
  }

  .cv-grid-item .right {
    font-size: 9pt;
    color: #666;
    text-align: right;
    flex-shrink: 0;
  }

  .cv-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2pt 12pt;
    font-size: 9pt;
  }

  .skill-label {
    font-weight: 600;
  }

  .cv-hobbies {
    font-size: 9pt;
    color: #444;
  }

  /* Publications - Grid layout */
  .cv-pub-entry {
    display: grid;
    grid-template-columns: 52pt 1fr;
    gap: 6pt;
    margin-bottom: 6pt;
    align-items: start;
  }

  .cv-pub-venue {
    font-size: 9pt;
    color: #555;
    font-weight: 700;
    padding-top: 1pt;
  }

  .cv-pub-main {
    display: flex;
    flex-direction: column;
    gap: 1pt;
  }

  .cv-pub-title {
    font-weight: 600;
    font-size: 10pt;
    line-height: 1.3;
    color: #1a1a1a;
  }

  .cv-pub-authors {
    font-size: 9pt;
    line-height: 1.4;
  }

  .cv-pub-links {
    display: flex;
    gap: 8pt;
    margin-top: 1pt;
  }

  /* Authors */
  .author-self {
    color: #1a1a1a;
  }

  .author-other {
    font-weight: 400;
    color: #666;
  }

  .author-sep {
    color: #999;
  }

  .pub-link {
    font-size: 8.5pt;
    color: #444;
    text-decoration: none;
  }

  .pub-link:hover {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .sep-dot {
    margin: 0 6pt;
    color: #999;
  }

  .project-name-link {
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 0.5pt solid #1a1a1a;
  }
</style>
