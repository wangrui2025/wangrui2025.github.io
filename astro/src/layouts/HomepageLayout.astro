---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import AuthorProfile from '../components/AuthorProfile.astro';
import PaperCard from '../components/PaperCard.astro';
import Education from '../components/Education.astro';
import ScholarBadge from '../components/ScholarBadge.astro';
import CvHonorItem from '../components/CvHonorItem.astro';
import { getEntry, getCollection } from 'astro:content';
import { TAG_URLS } from '../utils/constants';

export interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

// Get homepage content from Content Collection
const homepage = await getEntry('homepage', lang);
const h = homepage.data;

// Get scholar stats for citation badge
const scholarStats = await getEntry('scholar', 'stats');
const citedBy = scholarStats.data.citedby;

// Get honors data (sorted by rank - use spread to avoid mutation)
const honorsData = await getEntry('honors', 'honors');
const graduateHonors = [...honorsData.data.graduate].sort((a, b) => a.rank - b.rank);
const undergraduateHonors = [...honorsData.data.undergraduate].sort((a, b) => a.rank - b.rank);

// Get all papers and sort by date (descending - use spread to avoid mutation)
const allPapers = await getCollection('papers');
const sortedPapers = [...allPapers].sort(
  (a, b) => b.data.date.localeCompare(a.data.date)
);

const aboutMeLabel = lang === 'zh' ? '关于我' : 'About Me';
---

<BaseLayout
  title={h.title}
  description={h.description}
  lang={lang}
>
  <Sidebar slot="sidebar">
    <AuthorProfile lang={lang} />
  </Sidebar>

  <!-- About Me Section -->
  <section id="about-me" class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{aboutMeLabel}</h1>
    <p class="mb-4 text-lg" set:html={h.background.intro} />

    <!-- Background -->
    <div class="info-card mb-4">
      <h2 class="info-card-title">{h.background.heading}</h2>
      <ul class="about-list">
        {h.background.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <!-- Target Areas -->
    <div class="info-card">
      <h2 class="info-card-title">
        {h.target_areas.heading}
        <span class="text-sm font-normal text-gray-500 dark:text-gray-400 ml-2">{h.target_areas.subheading}</span>
      </h2>
      <ul class="about-list">
        {h.target_areas.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- News Section -->
  <section id="status" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.news_heading}
    </h2>
    <ul class="news-list">
      {h.news_items.map((item) => {
        // Chinese items
        if (item === '个人简历制作中') {
          return <li><a href="https://wangrui2025.github.io/zh/cv/" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        if (item === '正在准备 CVPR Slides') {
          return <li><a href="https://wangrui2025.github.io/slides.html" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        if (item === '正在准备 CVPR Poster') {
          return <li><a href="https://wangrui2025.github.io/latextab_in_html.html" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        // English items
        if (item === 'Building Personal CV') {
          return <li><a href="https://wangrui2025.github.io/zh/cv/" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        if (item === 'Preparing CVPR Slides') {
          return <li><a href="https://wangrui2025.github.io/slides.html" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        if (item === 'Preparing CVPR Poster') {
          return <li><a href="https://wangrui2025.github.io/latextab_in_html.html" class="text-link-primary dark:text-link-dark hover:underline">{item}</a></li>;
        }
        return <li>{item}</li>;
      })}
    </ul>
  </section>

  <!-- Timeline Section (hidden) -->
  <section id="timeline" class="mb-8" style="display: none;">
    <h2 class="section-heading text-2xl font-bold">
      {h.timeline_heading}
    </h2>
    <details class="timeline-details">
      <summary class="timeline-summary">
        <span class="toggle-icon">▶</span>
        <span class="toggle-text-collapsed">{h.timeline_collapsed_text}</span>
        <span class="toggle-text-expanded">{h.timeline_expanded_text}</span>
      </summary>
      <div class="timeline-container">
        {h.timeline_items.map((item) => (
          <div class="timeline-item">
            <div class="timeline-node"></div>
            <div class="timeline-content">
              <div class="timeline-period">{item.period}</div>
              <div class="timeline-title">{item.title}</div>
              {item.tags && item.tags.length > 0 && (
                <div class="timeline-tags">
                  {item.tags.map((tag) => (
                    TAG_URLS[tag] ? (
                      <a href={TAG_URLS[tag]} class="timeline-tag" target="_blank" rel="noopener noreferrer">{tag}</a>
                    ) : (
                      <span class="timeline-tag">{tag}</span>
                    )
                  ))}
                </div>
              )}
              <p class="timeline-description">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </details>
  </section>

  <!-- Publications Section -->
  <section id="publications" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_publications}
    </h2>
    {sortedPapers.map((paper) => (
      <PaperCard paper={paper} lang={lang} />
    ))}
  </section>

  <!-- Education Section -->
  <section id="educations" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_education}
    </h2>
    <Education lang={lang} />
  </section>

  <!-- Honors Section -->
  <section id="honors" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_honors}
    </h2>

    <h3 class="text-lg font-semibold mb-2">{h.honors_graduate_header}</h3>
    {graduateHonors.map((item) => (
      <CvHonorItem text={item[lang].text} period={item.period} secondary={false} />
    ))}

    <h3 class="text-lg font-semibold mb-2 mt-4">{h.honors_undergraduate_header}</h3>
    {undergraduateHonors.map((item) => (
      <CvHonorItem text={item[lang].text} period={item.period} secondary={false} />
    ))}
  </section>

  <!-- Project Section -->
  <section id="project" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_project}
    </h2>
    <ul class="project-list">
      <li>
        <a href={h.project_url} class="font-semibold hover:underline" target="_blank">
          {h.project_title}
        </a>
        <p class="text-gray-600 dark:text-gray-300 mt-1">{h.project_description}</p>
      </li>
    </ul>
  </section>

  <!-- Skills & Interests Section -->
  <section id="skills" class="mb-8">
    <h2 class="section-heading text-2xl font-bold">
      {h.section_skills}
    </h2>
    <ul class="skills-list">
      {h.skills_items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <!-- Google Scholar Badge -->
  <ScholarBadge citations={citedBy} />
</BaseLayout>
