---
import { execSync } from 'child_process';
import { ClientRouter } from 'astro:transitions';
import Masthead from '../components/Masthead.astro';
import Scripts from '../components/Scripts.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = 'Rui Wang - Homepage',
  description = 'Personal academic homepage of Rui Wang',
  lang = 'en',
  ogTitle,
  ogDescription,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://wangrui2025.github.io');

// Get the last commit date for "Last updated" display
let lastUpdated = '2026-04-03';
try {
  lastUpdated = execSync('git log -1 --format="%cs"', { cwd: '/Users/myk/Repo/wangrui2025.github.io' }).toString().trim();
} catch { /* CI env may lack git */ }
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Language alternates for SEO -->
    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site ?? 'https://wangrui2025.github.io')} />
    <link rel="alternate" hreflang="zh" href={new URL('/zh/', Astro.site ?? 'https://wangrui2025.github.io')} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site ?? 'https://wangrui2025.github.io')} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={title} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh-CN' : 'en'} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={new URL('/images/avatar.png', Astro.site ?? 'https://wangrui2025.github.io')} />

    <meta name="description" content={description} />

    <!-- Theme initialization - single source of truth via classList -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme')
          || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>

    <!-- Optimized Font Loading with preconnect and display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX: On-demand async loading only when .math elements exist -->
    <script is:inline>
      (function() {
        // Only load KaTeX if there are math elements on the page
        if (document.querySelector('.math')) {
          // Load CSS
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css';
          document.head.appendChild(link);

          // Load JS sequentially
          const loadScript = (src, onLoad) => {
            const script = document.createElement('script');
            script.src = src;
            script.onload = onLoad;
            document.head.appendChild(script);
          };

          loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js', function() {
            loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js', function() {
              renderMathInElement(document.querySelector('.math'), {
                delimiters: [
                  {left: '$$', right: '$$', display: true},
                  {left: '$', right: '$', display: false},
                  {left: '\\[', right: '\\]', display: true},
                  {left: '\\(', right: '\\)', display: false}
                ]
              });
            });
          });
        }
      })();
    </script>

    <!-- Client Router for seamless language switching (Astro 5) -->
    <ClientRouter fallback="none" />

    <!-- PWA Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    <!-- Schema.org Person Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Rui Wang",
        "alternateName": "王锐",
        "url": "https://wangrui2025.github.io",
        "jobTitle": "M.S. Candidate",
        "affiliation": {
          "@type": "Organization",
          "name": "Shenzhen University",
          "url": "https://www.szu.edu.cn"
        },
        "sameAs": [
          "https://scholar.google.com/citations?user=01amzbYAAAAJ",
          "https://github.com/wangrui2025",
          "https://orcid.org/0009-0001-0278-1985"
        ],
        "knowsAbout": [
          "Medical Imaging Analysis",
          "Echocardiography Video Segmentation",
          "Computer Vision",
          "Deep Learning"
        ]
      }
    </script>
  </head>

  <body class="bg-bg-primary text-text-primary dark:bg-bg-dark dark:text-text-dark">
    <a href="#main-content" class="skip-link bg-bg-primary text-link-primary dark:bg-bg-dark dark:text-link-dark">Skip to content</a>

    <Masthead lang={lang} />

    <div id="main" role="main">
      <slot name="sidebar" />

      <article class="page" itemscope itemtype="http://schema.org/CreativeWork">
        <meta
          itemprop="headline"
          content={title}
        />
        <div class="page__inner-wrap">
          <section class="page__content" itemprop="text" id="main-content">
            <slot />
          </section>
        </div>
      </article>
    </div>

    <Scripts />

    <footer class="footer-builtwith text-center py-6 text-xs text-text-primary/60 dark:text-text-dark/60 border-t border-border-primary dark:border-border-dark mt-8">
      {/* CN: 本网页由 */ /* EN: Built with */}
      {lang === 'zh' ? '本网页由' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener" class="text-link-primary dark:text-link-dark hover:underline">Astro</a> {lang === 'zh' ? '构建' : ''} · {lang === 'zh' ? '最后更新时间' : 'Last updated'}: {lastUpdated}
    </footer>
  </body>
</html>
