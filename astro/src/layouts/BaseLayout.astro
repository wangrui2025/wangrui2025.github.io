---
import { ClientRouter } from 'astro:transitions';
import Masthead from '../components/Masthead.astro';
import { SITE_URL } from '../utils/constants';
import { getLastUpdated } from '../utils/lastUpdated';
import { getPersonSchema } from '../utils/structuredData';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = 'Rui Wang - Homepage',
  description = 'Personal academic homepage of Rui Wang',
  lang = 'en',
  ogTitle,
  ogDescription,
} = Astro.props;

const siteUrl = Astro.site ?? SITE_URL;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Get the last commit date for "Last updated" display
const lastUpdated = getLastUpdated();

// Schema.org Person structured data
const personSchema = getPersonSchema({
  name: "Rui Wang",
  url: "https://wangrui2025.github.io",
  email: "wangrui2025@example.com",
  affiliation: "Shenzhen University",
  sameAs: [
    "https://scholar.google.com/citations?user=01amzbYAAAAJ",
    "https://github.com/wangrui2025",
    "https://orcid.org/0009-0001-0278-1985"
  ],
  description: "M.S. Candidate at Shenzhen University"
});
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <!-- Critical CSS: inline theme variables + base styles to prevent FOUC -->
    <!-- Loaded synchronously before render; full stylesheet loaded async by Vite -->
    <style is:inline>
      /* === Critical FOUC Prevention === */
      /* Light mode background — MUST be before any paint */
      html {
        background-color: #f5f4ed;
      }

      :root {
        --color-bg-primary: #f5f4ed;
        --color-bg-dark: #141413;
        --color-text-primary: #3d3d3d;
        --color-text-dark: #c9c9c9;
        --color-heading-primary: #141413;
        --color-heading-dark: #e8e8e8;
        --color-link-primary: #c96442;
        --color-link-dark: #d97757;
        --color-border-primary: #f0eee6;
        --color-border-dark: #30302e;
        --color-paper-bg: #faf9f5;
        --color-paper-bg-dark: #30302e;
        --color-paper-border: #f0eee6;
        --color-paper-border-dark: #30302e;
        --color-paper-accent: #c96442;
        --color-paper-accent-dark: #d97757;
        --color-tag-field-bg: #e8dcc8;
        --color-tag-field-bg-dark: #3d3529;
        --color-tag-field-text: #5e4a3a;
        --color-tag-field-text-dark: #c9b89a;
        --color-tag-tech-bg: #e8e6dc;
        --color-tag-tech-bg-dark: #3a3a36;
        --color-tag-tech-text: #4d4c48;
        --color-tag-tech-text-dark: #b0aea5;
        --color-scholar-badge-bg: #f6f6f6;
        --color-scholar-badge-bg-dark: #2d2d2d;
        --color-scholar-badge-count-bg: #ffffff;
        --color-scholar-badge-count-bg-dark: #121212;
        --color-scholar-icon: #4A90E2;
        --color-scholar-badge-text: #3d3d3d;
        --color-scholar-badge-text-dark: #c9c9c9;
        --color-scholar-badge-count: #4A90E2;
        --color-text-secondary: #5e5d59;
        --color-text-secondary-dark: #87867f;

        background-color: var(--color-bg-primary);
        color: var(--color-text-primary);
      }

      html.dark {
        background-color: #141413;
        --color-bg-primary: #141413;
        --color-text-primary: #c9c9c9;
        --color-heading-primary: #e8e8e8;
        --color-link-primary: #d97757;
        --color-border-primary: #30302e;
        --color-paper-bg: #30302e;
        --color-paper-border: #30302e;
        --color-paper-accent: #d97757;
        --color-tag-field-bg: #3d3529;
        --color-tag-field-text: #c9b89a;
        --color-tag-tech-bg: #3a3a36;
        --color-tag-tech-text: #b0aea5;
        --color-scholar-badge-bg: #2d2d2d;
        --color-scholar-badge-count-bg: #121212;
        --color-scholar-badge-text: #c9c9c9;
        --color-text-secondary: #87867f;

        background-color: var(--color-bg-primary);
        color: var(--color-text-primary);
      }

      /* Font family to reduce font flash */
      body {
        font-family: 'Inter', system-ui, -apple-system, 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans', sans-serif;
        line-height: 1.60;
        margin: 0;
      }

      /* Minimal layout to prevent shift */
      #main {
        display: flex;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
        gap: 2rem;
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        padding: 8px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus { top: 0; }

      /* Theme toggle button */
      .theme-toggle {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Icon visibility */
      .icon-sun { display: block; }
      .icon-moon { display: none; }
      html.dark .icon-sun { display: none; }
      html.dark .icon-moon { display: block; }

      /* View transitions — instant page switch */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
    </style>

    <!-- Theme initialization — runs BEFORE any paint to prevent FOUC -->
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme')
            || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Language alternates for SEO -->
    <link rel="alternate" hreflang="en" href={new URL('/', siteUrl)} />
    <link rel="alternate" hreflang="zh" href={new URL('/zh/', siteUrl)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl)} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rui Wang" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh-CN' : 'en'} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={new URL('/images/avatar.png', siteUrl)} />
    <meta property="og:image:alt" content="Rui Wang - Homepage Avatar" />

    <meta name="description" content={description} />

    <!-- Favicon & PWA -->
    <link id="pokemon-favicon" rel="icon" type="image/png" href="" />
    <script is:inline>
      (function() {
        var id = Math.floor(Math.random() * 151) + 1;
        var link = document.getElementById('pokemon-favicon');
        if (link) {
          link.href = 'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/' + id + '.png';
        }
      })();
    </script>
    <link rel="apple-touch-icon" href="/images/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />


    <!-- KaTeX: On-demand async loading only when .math elements exist -->
    <script is:inline>
      (function() {
        // Only load KaTeX if there are math elements on the page
        if (document.querySelector('.math')) {
          // Load CSS
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css';
          document.head.appendChild(link);

          // Load JS sequentially
          const loadScript = (src, onLoad) => {
            const script = document.createElement('script');
            script.src = src;
            script.onload = onLoad;
            document.head.appendChild(script);
          };

          loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js', function() {
            loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js', function() {
              renderMathInElement(document.querySelector('.math'), {
                delimiters: [
                  {left: '$$', right: '$$', display: true},
                  {left: '$', right: '$', display: false},
                  {left: '\\[', right: '\\]', display: true},
                  {left: '\\(', right: '\\)', display: false}
                ]
              });
            });
          });
        }
      })();
    </script>

    <!-- Client Router for seamless language switching (Astro 5) -->
    <ClientRouter fallback="none" />

    <!-- PWA Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    <!-- Schema.org Person Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
  </head>

  <body id="person" class="bg-bg-primary text-text-primary dark:bg-bg-dark dark:text-text-dark">
    <a href="#main-content" class="skip-link bg-bg-primary text-link-primary dark:bg-bg-dark dark:text-link-dark">Skip to content</a>

    <Masthead lang={lang} />

    <div id="main" role="main">
      <slot name="sidebar" />

      <article class="page" itemscope itemtype="http://schema.org/CreativeWork">
        <meta
          itemprop="headline"
          content={title}
        />
        <div class="page__inner-wrap">
          <section class="page__content" itemprop="text" id="main-content">
            <slot />
          </section>
        </div>
      </article>
    </div>

    <footer class="footer-builtwith text-center py-6 text-xs text-text-primary/60 dark:text-text-dark/60 border-t border-border-primary dark:border-border-dark mt-8">
      {lang === 'zh' ? '本网页由' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener" class="text-link-primary dark:text-link-dark hover:underline">Astro</a> {lang === 'zh' ? '构建' : ''} · {lang === 'zh' ? '最后更新时间' : 'Last updated'}: {lastUpdated}
    </footer>
  </body>
</html>
