---
import { ClientRouter } from 'astro:transitions';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import { SITE_URL } from '../utils/constants';
import { getLastUpdated } from '../utils/lastUpdated';
import { getPersonSchema } from '../utils/structuredData';
import '../styles/global.css';
import Favicon from '../components/Favicon.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'zh';
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = 'Rui Wang - Homepage',
  description = 'Personal academic homepage of Rui Wang',
  lang = 'en',
  ogTitle,
  ogDescription,
} = Astro.props;

const siteUrl = Astro.site ?? SITE_URL;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Get the last commit date for "Last updated" display
const lastUpdated = getLastUpdated();

// Schema.org Person structured data
const personSchema = getPersonSchema({
  name: "Rui Wang",
  url: "https://wangrui2025.github.io",
  email: "wangrui2025@example.com",
  affiliation: "Shenzhen University",
  sameAs: [
    "https://scholar.google.com/citations?user=01amzbYAAAAJ",
    "https://github.com/wangrui2025",
    "https://orcid.org/0009-0001-0278-1985"
  ],
  description: "M.S. Candidate at Shenzhen University"
});

---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Critical FOUC prevention — bare minimum, rest is in global.css (inlined by Vite) -->
    <style is:inline>
      html { background-color: #f5f4ed; }
      html.dark { background-color: #141413; }
    </style>

    <!-- Theme initialization — runs BEFORE any paint to prevent FOUC -->
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme')
            || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Language alternates for SEO -->
    <link rel="alternate" hreflang="en" href={new URL('/', siteUrl)} />
    <link rel="alternate" hreflang="zh" href={new URL('/zh/', siteUrl)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl)} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rui Wang" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh-CN' : 'en'} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={new URL('/images/avatar.png', siteUrl)} />
    <meta property="og:image:alt" content="Rui Wang - Homepage Avatar" />

    <meta name="description" content={description} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <Favicon />
    <link rel="manifest" href="/manifest.json" />


    <!-- KaTeX: On-demand async loading only when .math elements exist -->
    <script is:inline>
      (function() {
        // Only load KaTeX if there are math elements on the page
        if (document.querySelector('.math')) {
          // Load CSS
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css';
          document.head.appendChild(link);

          // Load JS sequentially
          const loadScript = (src, onLoad) => {
            const script = document.createElement('script');
            script.src = src;
            script.onload = onLoad;
            document.head.appendChild(script);
          };

          loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js', function() {
            loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js', function() {
              renderMathInElement(document.querySelector('.math'), {
                delimiters: [
                  {left: '$$', right: '$$', display: true},
                  {left: '$', right: '$', display: false},
                  {left: '\\[', right: '\\]', display: true},
                  {left: '\\(', right: '\\)', display: false}
                ]
              });
            });
          });
        }
      })();
    </script>

    <!-- Client Router for seamless language switching (Astro 5) -->
    <ClientRouter />

    <!-- PWA Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {
          // Service worker registration failed — site still works without SW
        });
        });
      }
    </script>

    <!-- Schema.org Person Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
  </head>

  <body id="person" class="bg-bg-primary text-text-primary dark:bg-bg-dark dark:text-text-dark">
    <a href="#main-content" class="skip-link bg-bg-primary text-link-primary dark:bg-bg-dark dark:text-link-dark">Skip to content</a>

    <Masthead lang={lang} />

    <div id="main" role="main">
      <slot name="sidebar" />

      <article class="page" itemscope itemtype="http://schema.org/CreativeWork">
        <meta
          itemprop="headline"
          content={title}
        />
        <div class="page__inner-wrap">
          <section class="page__content" itemprop="text" id="main-content">
            <slot />
          </section>
        </div>
      </article>
    </div>

    <Footer lang={lang} lastUpdated={lastUpdated} />
  </body>
</html>
