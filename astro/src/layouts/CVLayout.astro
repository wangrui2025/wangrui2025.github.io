---
import { execSync } from 'child_process';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  /** Fixed viewport width in pixels for CV pages (A4 ≈ 794px). Enables native PDF-like scaling on mobile. */
  viewport?: string;
}

const {
  title = 'Rui Wang - CV',
  description = 'Curriculum Vitae of Rui Wang',
  lang = 'zh',
  viewport = 'width=794',
} = Astro.props;

let lastUpdated = '2026-04-03';
try {
  lastUpdated = execSync('git log -1 --format="%cs"', { cwd: '/Users/myk/Repo/wangrui2025.github.io' }).toString().trim();
} catch { /* CI env may lack git */ }
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content={`${viewport}, initial-scale=1.0, user-scalable=yes`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme')
          || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <button id="export-pdf" class="pdf-btn" title={lang === 'zh' ? '导出 PDF' : 'Export PDF'}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>{lang === 'zh' ? '导出 PDF' : 'Export PDF'}</span>
    </button>

    <div class="cv-container">
      <div class="cv-wrapper">
        <slot />
      </div>
    </div>
    <footer class="footer-builtwith">
      {lang === 'zh' ? '本网页由' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> {lang === 'zh' ? '构建' : ''} · {lang === 'zh' ? '最后更新时间' : 'Last updated'}: {lastUpdated}
    </footer>

    <script>
      document.getElementById('export-pdf')?.addEventListener('click', () => {
        window.print();
      });
    </script>

    <style>
      @media print {
        @page {
          size: A4 portrait;
          margin: 0;
        }

        html, body {
          width: 210mm;
          height: 297mm;
          margin: 0 !important;
          padding: 0 !important;
          background: white !important;
        }

        .pdf-btn,
        .footer-builtwith {
          display: none !important;
        }

        .cv-wrapper {
          padding: 0 !important;
          margin: 0 !important;
          background: white !important;
        }

        .cv-page {
          width: 210mm !important;
          min-height: 297mm !important;
          max-width: 210mm !important;
          margin: 0 !important;
          padding: 15mm 20mm !important;
          box-shadow: none !important;
        }
      }
    </style>
  </body>
</html>

<style>
  .pdf-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #333;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .pdf-btn:hover {
    background: #555;
  }

  .cv-container {
    min-height: calc(100vh - 40px);
    display: flex;
    justify-content: center;
    padding: 20px;
    background: var(--bg-primary);
    overflow-x: auto;
  }

  .cv-wrapper {
    flex-shrink: 0;
  }

  .footer-builtwith {
    text-align: center;
    padding: 12px;
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-primary);
  }

  .footer-builtwith a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-builtwith a:hover {
    text-decoration: underline;
  }
</style>
