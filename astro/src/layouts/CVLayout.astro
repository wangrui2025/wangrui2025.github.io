---
import { getLastUpdated } from '../utils/lastUpdated';
import { SITE_URL } from '../utils/constants';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  /** Fixed viewport width in pixels for CV pages (A4 ≈ 794px). Enables native PDF-like scaling on mobile. */
  viewport?: string;
}

const {
  title = 'Rui Wang - CV',
  description = 'Curriculum Vitae of Rui Wang',
  lang = 'zh',
  viewport = 'width=794',
} = Astro.props;

const siteBase = 'https://wangrui2025.github.io';
const canonicalURL = new URL(lang === 'zh' ? '/zh/cv/' : '/cv/', siteBase);
const lastUpdated = getLastUpdated();
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content={`${viewport}, initial-scale=1.0, user-scalable=yes`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Language alternates for SEO -->
    <link rel="alternate" hreflang="en" href={new URL('/cv/', siteBase)} />
    <link rel="alternate" hreflang="zh" href={new URL('/zh/cv/', siteBase)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/cv/', siteBase)} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rui Wang" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh-CN' : 'en'} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/images/avatar.png', siteBase)} />
    <meta property="og:image:alt" content="Rui Wang - CV Avatar" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/avatar.png', siteBase)} />

    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <script is:inline>
      (function(){
        const t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');
        document.documentElement.classList.toggle('dark',t==='dark');
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <button id="export-pdf" class="fixed top-5 right-5 z-[1000] flex items-center gap-1.5 px-3.5 py-2 bg-gray-800 dark:bg-gray-700 text-white border-none rounded-md text-[13px] cursor-pointer transition-all duration-200 hover:bg-gray-600 shadow-md" title={lang === 'zh' ? '导出 PDF' : 'Export PDF'}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>{lang === 'zh' ? '导出 PDF' : 'Export PDF'}</span>
    </button>

    <div class="min-h-[calc(100vh-40px)] flex justify-center p-5 bg-bg-primary dark:bg-bg-dark overflow-x-auto">
      <div class="shrink-0">
        <slot />
      </div>
    </div>
    <footer class="text-center py-3 text-xs text-text-primary/50 dark:text-text-dark/50 bg-bg-primary dark:bg-bg-dark">
      {lang === 'zh' ? '本网页由' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener" class="text-text-primary/50 dark:text-text-dark/50 hover:underline">Astro</a> {lang === 'zh' ? '构建' : ''} · {lang === 'zh' ? '最后更新时间' : 'Last updated'}: {lastUpdated}
    </footer>

    <script>
      const A4_HEIGHT_PX = 1123; // 297mm * 3.78px/mm at 96dpi

      function setupPrintScale() {
        const page = document.querySelector('.cv-page') as HTMLElement | null;
        if (!page) return;
        const contentHeight = page.scrollHeight;
        if (contentHeight > A4_HEIGHT_PX) {
          // zoom is applied to the root html element so ALL content scales proportionally
          // including font sizes, margins, everything — this is what forces single-page
          const zoomPct = Math.round((A4_HEIGHT_PX / contentHeight) * 100);
          document.documentElement.style.setProperty('--print-zoom', `${zoomPct}%`);
        }
      }

      function resetPrintScale() {
        document.documentElement.style.setProperty('--print-zoom', '');
      }

      document.getElementById('export-pdf')?.addEventListener('click', () => {
        // Reset before measuring in case a previous print was cancelled
        resetPrintScale();
        // Wait for fonts + TWO paint cycles (double rAF) to ensure layout is final
        document.fonts.ready.then(() => {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              setupPrintScale();
              window.print();
            });
          });
        });
      });

      // Reliable cleanup: reset on afterprint + on next click (safety)
      window.addEventListener('afterprint', resetPrintScale);
    </script>

    <style>
      /* JS-calculated zoom applied here — forces everything (fonts, margins, padding)
         to scale proportionally so content fits exactly 1 page */
      @media print {
        @page {
          size: A4 portrait;
          margin: 0;
        }

        html, body {
          width: 210mm;
          height: 297mm;
          margin: 0 !important;
          padding: 0 !important;
          background: white !important;
          /* zoom scales the entire layout tree — this is what forces single-page */
          zoom: var(--print-zoom, 100%) !important;
        }

        #export-pdf,
        footer {
          display: none !important;
        }

        .shrink-0 {
          padding: 0 !important;
          margin: 0 !important;
          background: white !important;
        }

        :global(.cv-page) {
          width: 210mm !important;
          min-height: 0 !important;
          height: auto !important;
          max-width: 210mm !important;
          margin: 0 !important;
          padding: 15mm 20mm !important;
          box-shadow: none !important;
          /* Ensure no overflow within the scaled container */
          overflow: hidden !important;
        }
      }
    </style>
  </body>
</html>
