---
import { execSync } from 'child_process';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Rui Wang - CV',
  description = 'Curriculum Vitae of Rui Wang',
  lang = 'zh',
} = Astro.props;

let lastUpdated = '2026-04-03';
try {
  lastUpdated = execSync('git log -1 --format="%cs"', { cwd: '/Users/myk/Repo/wangrui2025.github.io' }).toString().trim();
} catch { /* CI env may lack git */ }
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme')
          || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  </head>
  <body>
    <button id="export-pdf" class="pdf-btn" title={lang === 'zh' ? '导出 PDF' : 'Export PDF'}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>{lang === 'zh' ? '导出 PDF' : 'Export PDF'}</span>
    </button>

    <div class="cv-wrapper">
      <slot />
    </div>
    <footer class="footer-builtwith">
      {lang === 'zh' ? '本网页由' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · {lang === 'zh' ? '最后更新时间' : 'Last updated'}: {lastUpdated}
    </footer>

    <script>
      document.getElementById('export-pdf')?.addEventListener('click', async () => {
        const btn = document.getElementById('export-pdf');
        const cvPage = document.querySelector('.cv-page') as HTMLElement;
        if (!btn || !cvPage) return;

        btn.setAttribute('disabled', 'true');
        btn.textContent = '生成中...';

        try {
          const opt = {
            margin: 0,
            filename: 'CV_王锐.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 1.2, useCORS: true, logging: false },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
            pagebreak: { mode: 'avoid-all' }
          };
          await html2pdf().set(opt).from(cvPage).save();
        } catch (e) {
          console.error(e);
        } finally {
          btn.removeAttribute('disabled');
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg><span>导出 PDF</span>`;
        }
      });
    </script>
  </body>
</html>

<style>
  .pdf-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #333;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .pdf-btn:hover {
    background: #555;
  }

  .pdf-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .cv-wrapper {
    min-height: calc(100vh - 40px);
    display: flex;
    justify-content: center;
    padding: 20px;
    background: var(--bg-primary);
  }

  .footer-builtwith {
    text-align: center;
    padding: 12px;
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-primary);
  }

  .footer-builtwith a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-builtwith a:hover {
    text-decoration: underline;
  }
</style>
