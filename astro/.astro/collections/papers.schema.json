{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "venue": {
      "type": "string"
    },
    "venue_full": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "alt_zh": {
      "type": "string"
    },
    "alt_en": {
      "type": "string"
    },
    "arxiv": {
      "type": "string",
      "pattern": "^https?:\\/\\/.+"
    },
    "project": {
      "type": "string",
      "pattern": "^https?:\\/\\/.+"
    },
    "equal_contribution": {
      "type": "boolean"
    },
    "show_on_cv": {
      "default": true,
      "type": "boolean"
    },
    "show_on_homepage": {
      "default": true,
      "type": "boolean"
    },
    "zh": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "is_corresponding": {
                "default": false,
                "type": "boolean"
              },
              "is_self": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "name"
            ]
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "authors",
        "fields",
        "technologies"
      ]
    },
    "en": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "is_corresponding": {
                "default": false,
                "type": "boolean"
              },
              "is_self": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "name"
            ]
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "authors",
        "fields",
        "technologies"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "date",
    "venue",
    "venue_full",
    "image",
    "alt_zh",
    "alt_en",
    "zh",
    "en"
  ]
}