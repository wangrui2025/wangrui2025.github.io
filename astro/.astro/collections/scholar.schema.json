{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "scholar_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "affiliation": {
      "type": "string"
    },
    "email_domain": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "citedby": {
      "type": "number"
    },
    "citedby5y": {
      "type": "number"
    },
    "hindex": {
      "type": "number"
    },
    "hindex5y": {
      "type": "number"
    },
    "i10index": {
      "type": "number"
    },
    "i10index5y": {
      "type": "number"
    },
    "cites_per_year": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "updated": {
      "type": "string"
    },
    "papers": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "arxiv_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "citations": {
            "type": "number"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "arxiv_id",
          "title",
          "citations",
          "authors"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "scholar_id",
    "name",
    "affiliation",
    "email_domain",
    "homepage",
    "interests",
    "citedby",
    "citedby5y",
    "hindex",
    "hindex5y",
    "i10index",
    "i10index5y",
    "cites_per_year",
    "updated"
  ]
