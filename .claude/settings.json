{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(./scripts/autopush.sh *)",
      "Bash(bash scripts/autopush.sh *)",
      "Bash(scripts/autopush.sh *)",
      "Bash(python3 scripts/fetch_scholar.py)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "Edit(.claude/*)",
      "Write(.claude/*)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/autopush.sh 2>&1 | head -10 || true",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
