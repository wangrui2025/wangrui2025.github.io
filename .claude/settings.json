{
  "permissions": {
    "allow": [
      "Bash(curl -sI https://mykcs.github.io/zh/)",
      "Bash(curl -s https://mykcs.github.io/zh/)",
      "Bash(curl -sI https://mykcs.github.io/assets/css/main.css)",
      "Bash(mkdir -p /Users/myk/Repo/mykcs/assets/files)",
      "Bash(printf '%PDF-1.4\\\\n1:*)",
      "Bash(git:*)",
      "Edit(.claude)",
      "Write(.claude)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(sudo gem:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/myk/Repo/wangrui2025.github.io && bash scripts/autopush.sh 2>&1 | head -10 || true",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
